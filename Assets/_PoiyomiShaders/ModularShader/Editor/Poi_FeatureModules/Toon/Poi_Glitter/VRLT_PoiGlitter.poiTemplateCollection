#T#PoiGlitterFunctions
//ifex _GlitterEnable==0
#ifdef _SUNDISK_SIMPLE

    float3 RandomColorFromPoint(float2 rando, float hue)
    {
        float saturation = lerp(_GlitterMinMaxSaturation.x, _GlitterMinMaxSaturation.y, rando.x);
        float value = lerp(_GlitterMinMaxBrightness.x, _GlitterMinMaxBrightness.y, rando.y);
        return HSVtoRGB(float3(hue, saturation, value));
    }

    float2 glitterComputeRotation(float2 pos, float2 center, float2 randomSeed, float timeOffset)
    {
        float randomBoy = poiRand(randomSeed);
        float rotSpeed = lerp(_GlitterRandomRotationSpeed.x, _GlitterRandomRotationSpeed.y, randomBoy);
        float randomOffset = _GlitterRandomRotation ? randomBoy : 0;
        float totalSpeed = _GlitterTextureRotation + rotSpeed;
        if (totalSpeed == 0 && timeOffset != 0)
            totalSpeed = 1;
        float theta = radians(randomOffset * 360 + (POI_TIME.x + timeOffset) * totalSpeed * 360);
        float cs = cos(theta);
        float sn = sin(theta);
        return float2((pos.x - center.x) * cs - (pos.y - center.y) * sn + center.x,
                      (pos.x - center.x) * sn + (pos.y - center.y) * cs + center.y);
    }

    void processGlitterParticle(
        inout PoiFragData poiFragData, in PoiMesh poiMesh, in PoiCam poiCam, in PoiLight poiLight, in PoiMods poiMods,
        float2 randPoint, float2 diff,
        float3 norm, float jaggyFix, float glitterFwidth, float glitterSpeedOffset, float glitterRotationTimeOffset,
        bool needsRotation, float glitterMask, float glitterMaxBrightness, float glitterBrightnessOffset)
    {
        float dist = length(diff);
        float randomFromPoint = poiRand(randPoint);
        float size = _GlitterSize;
        if (_GlitterRandomSize)
            size = lerp(_GlitterMinMaxSize.x, _GlitterMinMaxSize.y, randomFromPoint);
        #ifdef POI_AUDIOLINK
            if (_GlitterALEnabled)
                size = saturate(size + lerp(_GlitterALSizeAdd.x, _GlitterALSizeAdd.y, poiMods.audioLink[_GlitterALSizeAddBand]));
        #endif

        float2 rotatedDiff = diff;
        half glitterAlpha = 1;
        switch (_GlitterShape)
        {
            case 0:
            {
                if (_GlitterMode == 1)
                {
                    float sqDist = dot(diff, diff);
                    glitterAlpha = saturate((size - sqDist) / clamp(fwidth(sqDist), 0.0001, 1.0));
                }
                else
                {
                    glitterAlpha = saturate((size - dist) / glitterFwidth);
                }
                break;
            }
            case 1:
            {
                if (needsRotation)
                    rotatedDiff = glitterComputeRotation(diff, 0, randPoint * 200, glitterRotationTimeOffset);
                float squareAA = max(glitterFwidth, .1 * jaggyFix);
                glitterAlpha = (1. - smoothstep(size - squareAA, size, abs(rotatedDiff.x))) * (1. - smoothstep(size - squareAA, size, abs(rotatedDiff.y)));
                break;
            }
        }

        if (glitterAlpha <= 0) return;

        float3 finalGlitter = 0;
        half3 glitterColor = poiThemeColor(poiMods, _GlitterColor.rgb, _GlitterColorThemeIndex);
        float3 randomRotation = 0;

        switch (_GlitterMode)
        {
            case 0:
            {
                if (_GlitterSpeed + glitterSpeedOffset > 0)
                    randomRotation = randomFloat3WiggleRange(randPoint, _GlitterAngleRange, _GlitterSpeed, glitterSpeedOffset);
                else
                    randomRotation = poiRand3Range(randPoint, _GlitterAngleRange);
                float3 glitterReflectionDirection = normalize(mul(poiRotationMatrixFromAngles(randomRotation), norm));
                finalGlitter = lerp(0, _GlitterMinBrightness * glitterAlpha, glitterAlpha) + max(pow(saturate(dot(lerp(glitterReflectionDirection, poiCam.viewDir, _GlitterBias), poiCam.viewDir)), _GlitterContrast), 0);
                finalGlitter *= glitterAlpha;
                break;
            }
            case 1:
            {
                float3 cellRand3 = float3(poiRand(randPoint), poiRand(randPoint + 0.5), poiRand(randPoint.yx));
                float3 glitterNorm = abs(frac(cellRand3 * 14.274 + (POI_TIME.x + glitterSpeedOffset) * _GlitterLinearSpeed) * 2.0 - 1.0);
                glitterNorm = normalize(glitterNorm * 2.0 - 1.0);
                float3 glitterCamDir = lerp(poiCam.forwardDir, poiCam.viewDir, _GlitterLinearVRParallax);
                float glitterDot = dot(glitterNorm, glitterCamDir);
                float glitterVal = abs(frac(glitterDot * _GlitterLinearSensitivity + _GlitterLinearSensitivity) - 0.5) * 4.0 - 1.0;
                glitterVal = saturate(1.0 - (glitterVal * _GlitterLinearContrast + _GlitterLinearContrast));
                glitterVal = pow(glitterVal, _GlitterLinearPostContrast);
                float3 linearHalfDir = normalize(poiCam.viewDir + poiLight.direction * _GlitterLinearLightDirection);
                float linearNDotH = saturate(dot(norm, linearHalfDir));
                glitterVal = saturate(glitterVal * saturate(linearNDotH * _GlitterLinearAngle + 1.0 - _GlitterLinearAngle));
                finalGlitter = max(_GlitterLinearMinBrightness, glitterVal) * glitterAlpha;
                break;
            }
            case 2:
            {
                if (_GlitterSpeed + glitterSpeedOffset > 0)
                    randomRotation = randomFloat3WiggleRange(randPoint, _GlitterAngleRange, _GlitterSpeed, glitterSpeedOffset);
                else
                    randomRotation = poiRand3Range(randPoint, _GlitterAngleRange);
                float3 glitterLightReflectionDirection = normalize(mul(poiRotationMatrixFromAngles(randomRotation), norm));
                half lightAlpha = glitterAlpha * poiLight.nDotLSaturated;
                float3 halfDir = normalize(poiLight.direction + poiCam.viewDir);
                float specAngle = max(dot(halfDir, glitterLightReflectionDirection), 0.0);
                finalGlitter = lerp(0, _GlitterMinBrightness * lightAlpha, lightAlpha) + max(pow(specAngle, _GlitterContrast), 0);
                glitterColor *= poiLight.directColor;
                finalGlitter *= lightAlpha;
                break;
            }
        }

        glitterColor *= lerp(1, poiFragData.baseColor, _GlitterUseSurfaceColor);
        #if defined(PROP_GLITTERCOLORMAP) || !defined(OPTIMIZER_ENABLED)
            glitterColor *= POI2D_SAMPLER_PANGRAD(_GlitterColorMap, _MainTex, poiUV(poiMesh.uv[_GlitterColorMapUV], _GlitterColorMap_ST), _GlitterColorMapPan, poiMesh.dx, poiMesh.dy).rgb;
        #endif

        float2 uv = remapClamped(-size, size, rotatedDiff, 0, 1);
        if (!_GlitterShape && needsRotation)
            uv = glitterComputeRotation(uv, .5, randPoint * 200, glitterRotationTimeOffset);

        #if defined(PROP_GLITTERTEXTURE) || !defined(OPTIMIZER_ENABLED)
            float2 glitterTexUV = uv;
            if (_GlitterSpriteSheetEnabled)
            {
                float glitterSeed = poiRand(randPoint);
                float frameMode = _GlitterSpriteSheetFrameSelection == 1 ? 2 : 0;
                float glitterFrameIndex = poiSpriteSheetFrameIndex(
                    _GlitterSpriteSheetColumns, _GlitterSpriteSheetRows, _GlitterSpriteSheetTotalFrames,
                    frameMode, _GlitterSpriteSheetFPS, _GlitterSpriteSheetRandomStart,
                    0, glitterSeed);
                glitterTexUV = poiSpriteSheetUV(uv, _GlitterSpriteSheetColumns, _GlitterSpriteSheetRows, glitterFrameIndex, 0, _GlitterTexture_ST.xy);
            }
            float2 finalGlitterTexUV = poiUV(glitterTexUV, _GlitterTexture_ST);
            if (_GlitterTexturePixelMode)
                finalGlitterTexUV = sharpSample(_GlitterTexture_TexelSize, finalGlitterTexUV);
            float4 glitterTexture = POI2D_SAMPLER_PANGRAD(_GlitterTexture, _linear_clamp, finalGlitterTexUV, 0, poiMesh.dx, poiMesh.dy);
        #else
            float4 glitterTexture = 1;
        #endif
        glitterColor *= glitterTexture.rgb;

        float2 colorRando = poiRand2(randPoint.x + randPoint.y);
        float randomHue = poiRand(colorRando);
        if (_GlitterRandomColors)
            glitterColor *= RandomColorFromPoint(colorRando, randomHue);
        if (_GlitterHueShiftEnabled)
        {
            float hueOffset = _GlitterHueShift + POI_TIME.x * _GlitterHueShiftSpeed;
            if (_GlitterHueShiftRandomOffset)
                hueOffset += randomHue;
            glitterColor.rgb = hueShift(glitterColor.rgb, hueOffset, _GlitterHueShiftColorSpace, _GlitterHueSelectOrShift);
        }

        #ifdef POI_AUDIOLINK
        if(poiMods.audioLinkAvailable && _GlitterALEnabled && _GlitterALColorOverrideEnabled)
        {
            float alColorOverrideIntensity = poiMods.audioLink[_GlitterALColorOverrideBand];
            float alColorOverrideBlend = evalRamp4(alColorOverrideIntensity, _GlitterALColorOverrideRamp);
            if(alColorOverrideBlend > 0)
            {
                float3 alOverrideColor = _GlitterALColorOverride.rgb;
                if(_GlitterALColorOverrideThemeIndex > 0)
                {
                    alOverrideColor = poiThemeColor(poiMods, alOverrideColor, _GlitterALColorOverrideThemeIndex);
                }
                glitterColor = lerp(glitterColor, alOverrideColor, alColorOverrideBlend);
            }
        }
        #endif

        if (_GlitterBlendType == 1)
        {
            poiFragData.baseColor = lerp(poiFragData.baseColor, finalGlitter * glitterColor * (glitterMaxBrightness + glitterBrightnessOffset), finalGlitter * glitterTexture.a * glitterMask);
            poiFragData.emission += finalGlitter * glitterColor * max(0, ((glitterMaxBrightness + glitterBrightnessOffset) - 1) * glitterTexture.a) * glitterMask;
        }
        else
        {
            poiFragData.emission += finalGlitter * glitterColor * (glitterMaxBrightness + glitterBrightnessOffset) * glitterTexture.a * glitterMask;
        }
    }

    void applyGlitter(inout PoiFragData poiFragData, in PoiMesh poiMesh, in PoiCam poiCam, in PoiLight poiLight, in PoiMods poiMods)
    {
        float glitterRotationTimeOffset = 0;
        #ifdef POI_AUDIOLINK
            if (_GlitterALEnabled)
            {
                glitterRotationTimeOffset += AudioLinkGetChronoTime(_GlitterALChronoRotationSpeedType, _GlitterALChronoRotationSpeedBand) * _GlitterALChronoRotationSpeed;
            }
        #endif
        bool needsRotation = _GlitterRandomRotation || _GlitterTextureRotation != 0 || any(_GlitterRandomRotationSpeed.xy) || glitterRotationTimeOffset != 0;
        
        // Pre-compute values shared across all layers and cells
        float3 norm = lerp(poiMesh.normals[0], poiMesh.normals[1], _GlitterUseNormals);
        float jaggyFix = pow(poiCam.distanceToVert, 2) * _GlitterJaggyFix;
        float glitterSpeedOffset = 0;
        #ifdef POI_AUDIOLINK
            if (_GlitterALEnabled)
                glitterSpeedOffset = AudioLinkGetChronoTime(_GlitterALChronoSparkleSpeedType, _GlitterALChronoSparkleSpeedBand) * _GlitterALChronoSparkleSpeed;
        #endif
        
        #if defined(PROP_GLITTERMASK) || !defined(OPTIMIZER_ENABLED)
            float glitterMask = POI2D_SAMPLER_PAN(_GlitterMask, _MainTex, poiUV(poiMesh.uv[_GlitterMaskUV], _GlitterMask_ST), _GlitterMaskPan)[_GlitterMaskChannel];
        #else
            float glitterMask = 1;
        #endif
        #ifdef POI_AUDIOLINK
            if (_GlitterALEnabled)
                glitterMask = clamp(glitterMask + lerp(_GlitterALAlphaAdd.x, _GlitterALAlphaAdd.y, poiMods.audioLink[_GlitterALAlphaAddBand]), 0, glitterMask);
        #endif
        if (_GlitterMaskInvert)
            glitterMask = 1 - glitterMask;
        glitterMask *= lerp(1, poiLight.rampedLightMap * poiLight.attenuation, _GlitterHideInShadow);
        glitterMask *= lerp(1, poiLight.directLuminance, _GlitterScaleWithLighting);
        glitterMask *= _GlitterColor.a;
        if (_GlitterMaskGlobalMask > 0)
            glitterMask = maskBlend(glitterMask, poiMods.globalMask[_GlitterMaskGlobalMask - 1], _GlitterMaskGlobalMaskBlendType);
        if (glitterMask <= 0) return;
        
        float glitterBrightnessOffset = 0;
        #ifdef POI_AUDIOLINK
            if (_GlitterALEnabled)
                glitterBrightnessOffset = max(lerp(_GlitterALMaxBrightnessAdd.x, _GlitterALMaxBrightnessAdd.y, poiMods.audioLink[_GlitterALMaxBrightnessBand]), 0);
        #endif
        float glitterMaxBrightness = _GlitterMode == 1 ? _GlitterLinearBrightness : _GlitterBrightness;
        
        float maxSize = _GlitterRandomSize ? _GlitterMinMaxSize.y : _GlitterSize;
        #ifdef POI_AUDIOLINK
            if (_GlitterALEnabled)
                maxSize = saturate(maxSize + max(_GlitterALSizeAdd.x, _GlitterALSizeAdd.y));
        #endif
        
        float2 st = (poiMesh.uv[_GlitterUV] + _GlitterUVPanning.xy * POI_TIME.x) * _GlitterFrequency;
        float2 dd = fwidth(st);
        float distanceLODEnabled = _GlitterMode == 1 ? _GlitterLinearDistanceLOD : _GlitterDistanceLOD;
        float glitterFwidth = clamp(length(dd), 0.0001, 1.0);
        if (distanceLODEnabled)
        {
            float lodFactor = frac(sin(dot(floor(st / floor(dd + 3.0)), float2(12.9898, 78.233))) * 46203.4357) + 0.5;
            float2 lodScale = floor(dd + lodFactor * 0.5);
            st = st / max(1.0, lodScale) + _GlitterFrequency * lodScale;
        }
        
        [loop] for (uint glitterLayer = 0; glitterLayer < uint(_GlitterLayers); glitterLayer++)
        {
            float2 i_st = floor(st);
            float2 f_st = frac(st);
            
            float m_dist = 10.;
            float2 randoPoint = 0;
            float2 closestDiff = 0;
            
            [loop] for (int cellJ = -1; cellJ <= 1; cellJ++)
            {
                [loop] for (int cellI = -1; cellI <= 1; cellI++)
                {
                    float2 neighbor = float2(cellI, cellJ);
                    float2 cellRando = poiRand2(i_st + neighbor + glitterLayer * 0.5141);
                    float2 cellDiff = neighbor + cellRando * _GlitterRandomLocation - f_st;
                    float cellDist = length(cellDiff);
                    
                    UNITY_BRANCH
                    if (_GlitterFullCoverage)
                    {
                        if (cellDist > maxSize + 1.0) continue;
                        processGlitterParticle(poiFragData, poiMesh, poiCam, poiLight, poiMods,
                            cellRando, cellDiff,
                            norm, jaggyFix, glitterFwidth, glitterSpeedOffset, glitterRotationTimeOffset,
                            needsRotation, glitterMask, glitterMaxBrightness, glitterBrightnessOffset);
                    }
                    else
                    {
                        // Original: find closest point only
                        if (cellDist < m_dist)
                        {
                            closestDiff = cellDiff;
                            m_dist = cellDist;
                            randoPoint = cellRando;
                        }
                    }
                }
            }
            
            UNITY_BRANCH
            if (!_GlitterFullCoverage)
            {
                processGlitterParticle(poiFragData, poiMesh, poiCam, poiLight, poiMods,
                    randoPoint, closestDiff,
                    norm, jaggyFix, glitterFwidth, glitterSpeedOffset, glitterRotationTimeOffset,
                    needsRotation, glitterMask, glitterMaxBrightness, glitterBrightnessOffset);
            }
        }
    }
#endif
