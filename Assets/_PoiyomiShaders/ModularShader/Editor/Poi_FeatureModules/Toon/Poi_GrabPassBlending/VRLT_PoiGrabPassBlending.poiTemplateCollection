#T#PoiGrabPassBlendingFunctions
//ifex _EnableGrabpass==0
float4 grabpassBlur(float2 uv, float camDistance, float smoothness, float depthFade)
{
	float roughnessInfluence = lerp(1, 1 - smoothness, _GrabBlurUseSmoothness);
	float effectiveDistance = lerp(1, camDistance, _GrabBlurFalloff);
	float scale = WorldToScreenScale(_GrabBlurDistance * roughnessInfluence * depthFade * 0.1, effectiveDistance);
	float2 aspectCorrect = GetScreenAspectCorrection();
	
	float4 color = 0;
	float totalWeight = 0;
	int quality = floor(_GrabBlurQuality);
	int samples = quality * quality;
	
	switch (_GrabBlurPattern)
	{
		case 0: // Sunflower - Golden angle spiral
		{
			const float goldenAngle = 2.39996323;
			for (int i = 0; i < samples; i++)
			{
				float r = sqrt((i + 0.5) / samples);
				float theta = i * goldenAngle;
				float adjustedR = pow(r, _GrabBlurPower + 1);
				float2 offset = float2(cos(theta), sin(theta)) * adjustedR * scale * aspectCorrect;
				float weight = 1.0 - r * _GrabBlurPower;
				color += POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, uv + offset) * weight;
				totalWeight += weight;
			}
			break;
		}
		case 1: // Gaussian - Spiral with gaussian weights
		{
			const float goldenAngle = 2.39996323;
			for (int i = 0; i < samples; i++)
			{
				float r = sqrt((i + 0.5) / samples);
				float theta = i * goldenAngle;
				float2 offset = float2(cos(theta), sin(theta)) * r * scale * aspectCorrect;
				float weight = exp(-r * r * (3.0 + _GrabBlurPower * 5.0));
				color += POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, uv + offset) * weight;
				totalWeight += weight;
			}
			break;
		}
		case 2: // Hexagonal Bokeh - 6-sided shape (point at bottom)
		{
			const float goldenAngle = 2.39996323;
			const float hexRotation = UNITY_PI / 6.0;
			for (int i = 0; i < samples; i++)
			{
				float r = sqrt((i + 0.5) / samples);
				float theta = i * goldenAngle;
				float2 dir = float2(cos(theta), sin(theta));
				float sectorAngle = atan2(dir.y, dir.x) + hexRotation;
				float angleInSector = fmod(abs(sectorAngle), UNITY_PI / 3.0) - UNITY_PI / 6.0;
				float hexScale = cos(UNITY_PI / 6.0) / cos(angleInSector);
				float2 offset = dir * r * hexScale * scale * aspectCorrect;
				color += POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, uv + offset);
				totalWeight += 1.0;
			}
			break;
		}
	}

	color /= max(totalWeight, 1.0);
	return color;
}

float getGrabBlurDepthFade(float2 screenPos, float4 direction, float3 fragmentWorldPos)
{
	if (!_GrabBlurUseDepth) return 1;
	if (!DepthTextureExists()) return 1;
	
	float z = SampleScreenDepth(screenPos);
	
	float backgroundDepth = CorrectedLinearEyeDepth(z, direction.w);
	float3 backgroundWorldPos = direction.xyz * backgroundDepth + _WorldSpaceCameraPos.xyz;
	float depthDiff = distance(backgroundWorldPos, fragmentWorldPos);
	
	return lerp(_GrabBlurDepthRamp.x, _GrabBlurDepthRamp.y, smoothstep(_GrabBlurDepthRamp.z, _GrabBlurDepthRamp.w, depthDiff));
}

inline float4 Refraction(float indexOfRefraction, float chromaticAberration, float camDistance, float4 direction, in PoiMesh poiMesh, in PoiCam poiCam, in PoiMods poiMods, inout PoiLight poiLight, in PoiFragData poiFragData)
{
	poiLight.finalLighting = max(poiLight.finalLighting, EPSILON);
	float4 refractionColor;
	float3 worldViewDir = normalize(PoiWorldSpaceViewDir(poiMesh.worldPos));
	float3 refractionOffset = (((indexOfRefraction - 1.0) * mul(UNITY_MATRIX_V, float4(poiMesh.normals[1], 0.0)).xyz) * (1.0 - dot(poiMesh.normals[1], worldViewDir)));
	float2 cameraRefraction = float2(refractionOffset.x, - (refractionOffset.y * _ProjectionParams.x)) * GetFOVScale() / max(camDistance, 1.0);
	cameraRefraction *= pow(saturate(1.0 - poiLight.nDotV), _RefractionFresnelPower);

	float2 bgRes = poiGetWidthAndHeight(_PoiOpaqueTex);
	float aspect = bgRes.y / bgRes.x;
	cameraRefraction.x *= aspect;
	
	float2 refractedGrab = poiCam.screenUV + cameraRefraction;
	float depthFade = getGrabBlurDepthFade(refractedGrab, direction, poiMesh.worldPos);

	UNITY_BRANCH
	if (_RefractionChromaticAberration > 0)
	{
		float4 redAlpha = POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, (poiCam.screenUV + cameraRefraction));
		float green = POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, (poiCam.screenUV + (cameraRefraction * (1.0 - chromaticAberration)))).g;
		float blue = POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, (poiCam.screenUV + (cameraRefraction * (1.0 + chromaticAberration)))).b;
		refractionColor = float4(redAlpha.r, green, blue, redAlpha.a);
	}
	else
	{
		#ifdef CHROMATIC_ABERRATION_LOW
			refractionColor = grabpassBlur(refractedGrab, camDistance, poiFragData.smoothness, depthFade);
		#else
			refractionColor = POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, refractedGrab);
		#endif
	}
	return refractionColor;
}

void applyGrabEffects(inout PoiFragData poiFragData, in PoiCam poiCam, in PoiMesh poiMesh, inout PoiLight poiLight, in PoiMods poiMods)
{
	float camDistance = poiCam.distanceToVert;
	
	float perspectiveDivide = 1.0f / poiCam.clipPos.w;
	float4 direction = poiCam.worldDirection * perspectiveDivide;
	
	float3 grabpassColor = 1;
	UNITY_BRANCH
	if (_RefractionEnabled == 1)
	{
		grabpassColor = Refraction(_RefractionIndex, _RefractionChromaticAberration, camDistance, direction, poiMesh, poiCam, poiMods, poiLight, poiFragData).rgb;
	}
	else
	{
		float depthFade = getGrabBlurDepthFade(poiCam.screenUV, direction, poiMesh.worldPos);
		#ifdef CHROMATIC_ABERRATION_LOW
			grabpassColor = grabpassBlur(poiCam.screenUV, camDistance, poiFragData.smoothness, depthFade);
		#else
			grabpassColor = POI_SAMPLE_SCREEN(_PoiOpaqueTex, sampler_linear_clamp, poiCam.screenUV).rgb;
		#endif
	}
	
	float blendMap = 1;
	#if defined(PROP_GRABPASSBLENDMAP) || !defined(OPTIMIZER_ENABLED)
		blendMap = POI2D_SAMPLER_PAN(_GrabPassBlendMap, _MainTex, poiUV(poiMesh.uv[_GrabPassBlendMapUV], _GrabPassBlendMap_ST), _GrabPassBlendMapPan)[_GrabPassBlendMapChannel];
	#endif
	float blendFactor = _GrabPassBlendFactor * blendMap;
	if (_GrabPassBlendGlobalMask > 0)
	{
		blendFactor = customBlend(blendFactor, poiMods.globalMask[_GrabPassBlendGlobalMask - 1], _GrabPassBlendGlobalMaskBlendType);
	}

	if (_GrabPassUseAlpha)
	{
		blendFactor *= (1 - poiFragData.alpha);
	}

	grabpassColor = (_GrabpassColor.rgb * grabpassColor * _GrabPassBrightness) + (_GrabPassAddBrightness * _GrabpassColor.rgb);
	
	UNITY_BRANCH
	if (_GrabPassHueShiftToggle)
	{
		grabpassColor = hueShift(grabpassColor, frac(_GrabPassHueShift + _GrabPassHueShiftSpeed * POI_TIME.x), _GrabPassHueShiftColorSpace, _GrabPassHueSelectOrShift);
	}
	#ifdef POI_PASS_ADD
		poiFragData.baseColor = poiBlend(_GrabSrcBlend, float4(poiFragData.baseColor, poiFragData.alpha), _GrabDstBlend, float4(0, 0, 0, 1), blendFactor).rgb;
	#endif
	#ifdef POI_PASS_BASE
		poiFragData.baseColor = poiBlend(_GrabSrcBlend, float4(poiFragData.baseColor, poiFragData.alpha), _GrabDstBlend, float4(grabpassColor / poiLight.finalLighting, 1), blendFactor).rgb;
	#endif
}
//endex

