#T#PoiSubsurfaceScatteringFunctions
//ifex _SubsurfaceScattering==0
#ifdef POI_SUBSURFACESCATTERING
    void applySubsurfaceScattering(in PoiCam poiCam, inout PoiLight poiLight, in PoiMesh poiMesh, in PoiFragData poiFragData, in PoiMods poiMods)
    {
        float4 SSS = 1;
        #if defined(PROP_SSSTHICKNESSMAP) || !defined(OPTIMIZER_ENABLED)
            SSS = POI2D_SAMPLER_PAN(_SSSThicknessMap, _MainTex, poiUV(poiMesh.uv[_SSSThicknessMapUV], _SSSThicknessMap_ST), _SSSThicknessMapPan);
        #endif
        SSS.a = 1 - SSS.a;
        
        float3 vLTLight = poiLight.direction + poiMesh.normals[0] * _SSSDistortion;
        float flTDot = pow(saturate(dot(poiCam.viewDir, -vLTLight)), _SSSSpread) * _SSSStrength;
        #ifdef POI_PASS_BASE
            float3 fLT = (flTDot) * saturate(SSS.a + - 1 * _SSSThicknessMod);
        #else
            float3 fLT = poiLight.additiveShadow * (flTDot) * saturate(SSS.a + - 1 * _SSSThicknessMod);
        #endif
        
        float sssShadow = lerp(1, poiLight.attenuation, _SSSShadowStrength);

        float sssMask = 1;
        if (_SSSGlobalMaskIndex > 0)
            sssMask = maskBlend(sssMask, poiMods.globalMask[_SSSGlobalMaskIndex - 1], _SSSGlobalMaskBlendType);

        poiLight.finalLightAdd += fLT * lerp(1, poiLight.directColor, _SSSLightColorMix) * _SSSColor * SSS.rgb * sssShadow * lerp(1, poiFragData.baseColor, _SSSBaseColorMix) * sssMask;
    }
#endif
//endex

#T#PoiSubsurfaceScatteringFunctionCalls
//ifex _SubsurfaceScattering==0
#ifdef POI_SUBSURFACESCATTERING
    applySubsurfaceScattering(poiCam, poiLight, poiMesh, poiFragData, poiMods);
#endif
//endex