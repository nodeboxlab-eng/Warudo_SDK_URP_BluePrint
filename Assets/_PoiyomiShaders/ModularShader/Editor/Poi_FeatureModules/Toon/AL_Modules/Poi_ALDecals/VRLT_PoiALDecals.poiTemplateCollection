#T#PoiALDecalsFunctions
//ifex _EnableALDecal==0
#ifdef POI_AUDIOLINK
    #ifdef POI_AL_DECAL
        void ApplyAudioLinkDecal(in PoiMesh poiMesh, inout PoiFragData poiFragData, in PoiMods poiMods)
        {
            float4 colorAndMask = float4(1, 1, 1, 1);
            #if defined(PROP_ALDECALCOLORMASK) || !defined(OPTIMIZER_ENABLED)
                colorAndMask = POI2D_SAMPLER_PAN(_ALDecalColorMask, _MainTex, poiUV(poiMesh.uv[_ALDecalColorMaskUV], _ALDecalColorMask_ST), _ALDecalColorMaskPan);
            #endif
            if (_ALDecalGlobalMask > 0)
            {
                colorAndMask.a = customBlend(colorAndMask.a, poiMods.globalMask[_ALDecalGlobalMask-1], _ALDecalGlobalMaskBlendType);
            }

            float4 scaleOffset = float4(-_ALDecalSideOffset.x, _ALDecalSideOffset.y, -_ALDecalSideOffset.z, _ALDecalSideOffset.w);
            float2 centerOffset = float2((scaleOffset.x + scaleOffset.y) / 2, (scaleOffset.z + scaleOffset.w) / 2);
            float2 uv = poiMesh.uv[_ALDecalUV];
            float tilingClip = 1;
            // Symmetry
            if (_ALDecalSymmetryMode == 1) uv.x = abs(uv.x - 0.5) + 0.5;
            if (_ALDecalSymmetryMode == 2 && uv.x < 0.5) uv.x = uv.x + 0.5;
            // Mirrored UV
            if ((_ALDecalMirroredUVMode == 1 || _ALDecalMirroredUVMode == 4) && poiMesh.isRightHand) uv.x = 1.0 - uv.x;
            if (_ALDecalMirroredUVMode == 2 && poiMesh.isRightHand) tilingClip = 0;
            if ((_ALDecalMirroredUVMode == 3 || _ALDecalMirroredUVMode == 4) && !poiMesh.isRightHand) tilingClip = 0;

            float2 decalCenter = _ALDecalPosition + centerOffset;
            float theta = radians(_ALDecalRotation + POI_TIME.z * _ALDecalRotationSpeed);
            float cs = cos(theta);
            float sn = sin(theta);
            uv = float2((uv.x - decalCenter.x) * cs - (uv.y - decalCenter.y) * sn + decalCenter.x, (uv.x - decalCenter.x) * sn + (uv.y - decalCenter.y) * cs + decalCenter.y);
            uv = remap(uv, float2(0, 0) - _ALDecalScale / 2 + _ALDecalPosition + scaleOffset.xz, _ALDecalScale / 2 + _ALDecalPosition + scaleOffset.yw, float2(0, 0), float2(1, 1));
            // Tiling Clip
            if (!_ALDecalTiled)
            {
                if (uv.x > 1 || uv.y > 1 || uv.x < 0 || uv.y < 0)
                {
                    tilingClip = 0;
                }
            }
            uv = tilingClip > 0 ? frac(uv) : uv;

            // Mask
            float3 audioLinkMask = 1.0;

            // UV
            float2 aluv = uv;
            float maskY = aluv.y;
            float maskX = aluv.x;
            if (_ALDecalUVMode == 1)
            {
                float2 uvdir = uv * 2 - 1;
                aluv.x = frac(atan2(uvdir.y, uvdir.x) * UNITY_INV_TWO_PI);
                aluv.y = length(uvdir);
                maskY = remap(aluv.y, _ALDecaldCircleDimensions.x, _ALDecaldCircleDimensions.y, 0, 1);
                maskX = remap(aluv.x, _ALDecaldCircleDimensions.z, _ALDecaldCircleDimensions.w, 0, 1);
            }


            float maskVolume = _ALDecalVolumeStep != 0.0 ? floor(maskY * _ALDecalVolumeStep + 1e-4) / _ALDecalVolumeStep : maskY;
            float maskBand = _ALDecalBandStep != 0.0 ? floor(maskX * _ALDecalBandStep + 1e-4) / _ALDecalBandStep : maskX;

            // Mirror band axis (0->1->0 or 1->0->1)
            if (_ALDecalMirrorBand == 1)
            {
                maskBand = 1.0 - abs(maskBand * 2.0 - 1.0);
            }
            else if (_ALDecalMirrorBand == 2)
            {
                maskBand = abs(maskBand * 2.0 - 1.0);
            }

            // Copy
            audioLinkMask.r = maskVolume;
            audioLinkMask.g = maskBand;

            // Clip
            audioLinkMask.b = maskVolume < _ALDecalVolumeClipMin || maskVolume > _ALDecalVolumeClipMax ? 0.0 : audioLinkMask.b;
            audioLinkMask.b = maskBand < _ALDecalBandClipMin || maskBand > _ALDecalBandClipMax ? 0.0 : audioLinkMask.b;

            // Shape Clip (analytical filtered pulse for proper AA on all edges)
            if (_ALDecalShapeClip)
            {
                if (_ALDecalVolumeStep != 0.0)
                {
                    float vw = _ALDecalShapeClipVolumeWidth;
                    float gw = 1.0 - vw;
                    // Center the bar in each step so the gap straddles the step boundary
                    float volInput = maskY * _ALDecalVolumeStep - gw * 0.5;
                    float vdx = max(fwidth(volInput), 0.0001);
                    float vx0 = volInput - vdx * 0.5;
                    float vx1 = volInput + vdx * 0.5;
                    float vI0 = floor(vx0) * vw + min(frac(vx0), vw);
                    float vI1 = floor(vx1) * vw + min(frac(vx1), vw);
                    audioLinkMask.b *= saturate((vI1 - vI0) / vdx);
                }

                float bandwidth = _ALDecalUVMode == 1 ? _ALDecalShapeClipBandWidth / aluv.y : _ALDecalShapeClipBandWidth;
                float bandth = 1.0 - bandwidth;
                if (_ALDecalBandStep != 0.0)
                {
                    float bandInput = maskX * _ALDecalBandStep + bandth * 0.5;
                    float bdx = max(fwidth(bandInput), 0.0001);
                    float bx0 = bandInput - bdx * 0.5;
                    float bx1 = bandInput + bdx * 0.5;
                    float bI0 = floor(bx0) * bandth + min(frac(bx0), bandth);
                    float bI1 = floor(bx1) * bandth + min(frac(bx1), bandth);
                    audioLinkMask.b *= 1.0 - saturate((bI1 - bI0) / bdx);
                }
            }

            // Bilateral Mode
            float bilateralVolume = maskVolume;
            if (_ALDecalBilateral)
            {
                bilateralVolume = abs(maskVolume - 0.5) * 2.0;
            }

            // AudioLink
            float bandScale = 4.0 * _ALDecalBandRange;
            float alBandIndex = min(floor(audioLinkMask.g * bandScale), 3.0);
            float2 audioLinkUV = float2(frac(audioLinkMask.g * bandScale), (4.5 + alBandIndex) / 64.0);

            float audioVal;
            if (_ALDecalDebug)
            {
                float bandPos = maskBand;
                float bandHash = frac(sin(floor(bandPos * 128.0) * 43.7585) * 2847.15);
                float bassWeight = saturate(1.0 - bandPos * 2.0);
                float trebWeight = saturate(bandPos * 2.0 - 1.0);
                float midWeight = 1.0 - bassWeight - trebWeight;
                float speed = lerp(1.5, 6.0, bandPos);
                float t = POI_TIME.y;
                float pulse = saturate(sin(t * speed + bandHash * 6.283) * 0.7 + 0.3);
                pulse *= saturate(sin(t * speed * 0.37 + bandHash * 3.14) + 0.5);
                float beat = pow(saturate(sin(t * 1.8 + bandHash * 2.0) * 0.5 + 0.5), 2.0);
                audioVal = lerp(pulse, beat, bassWeight) * lerp(0.8, 0.3, trebWeight);
                audioVal *= _ALDecalVolume * lerp(_ALDecalBaseBoost, _ALDecalTrebleBoost, audioLinkMask.g);
            }
            else
            {
                float4 audioTexture = _AudioTexture.Sample(sampler_linear_clamp, audioLinkUV);
                audioVal = audioTexture.b * _ALDecalVolume * lerp(_ALDecalBaseBoost, _ALDecalTrebleBoost, audioLinkMask.g);
            }
            audioVal = tanh(audioVal);

            float audioLinkValue;
            if (_ALDecalLineWidth < 1.0 && _ALDecalVolumeStep != 0.0)
            {
                // Step percentage mode: lineWidth = percentage of total steps shown from top down (min 1 step)
                float stepSize = 1.0 / _ALDecalVolumeStep;
                float threshold = audioVal - max(_ALDecalLineWidth, stepSize);
                audioLinkValue = (audioVal > bilateralVolume && bilateralVolume >= threshold) ? 1.0 : 0.0;
            }
            else if (_ALDecalLineWidth < 1.0)
            {
                // Line mode (no steps active)
                float pixelSize = max(length(float2(ddx(bilateralVolume), ddy(bilateralVolume))), 0.0001);
                float thickness = _ALDecalLineWidth * 64.0;
                float marginUV = (thickness + 1.0) * pixelSize;
                float remappedAudio = lerp(marginUV, 1.0 - marginUV, audioVal);
                float d = abs(remappedAudio - bilateralVolume);
                float pixelDist = d / pixelSize;
                audioLinkValue = smoothstep(thickness + 1.0, thickness, pixelDist);
            }
            else
            {
                audioLinkValue = audioVal > bilateralVolume ? 1.0 : 0.0;
            }
            audioLinkValue = saturate(audioLinkValue) * audioLinkMask.b * tilingClip;
            //clip(audioLinkValue - .5);
            audioLinkValue *= colorAndMask.a;

            if (!_ALDecalDebug && !poiMods.audioLinkAvailable)
            {
                audioLinkValue = 0;
            }

            // Debug: draw perimeter border
            float debugBorder = 0;
            if (_ALDecalDebug && tilingClip > 0)
            {
                float bw = _ALDecalDebugBorderWidth;
                if (uv.x < bw || uv.x > 1 - bw || uv.y < bw || uv.y > 1 - bw)
                {
                    debugBorder = 1;
                }
            }

            float3 alColorChord = float3(0, 0, 0);
            if (_ALDecalColorMode == 1)
            {
                if (_ALDecalDebug)
                {
                    alColorChord = float3(
                        saturate(sin(POI_TIME.y * 2.1 + maskBand * 13.0) * 0.5 + 0.5),
                        saturate(sin(POI_TIME.y * 3.3 + maskBand * 7.7) * 0.5 + 0.5),
                        saturate(sin(POI_TIME.y * 4.7 + maskBand * 19.1) * 0.5 + 0.5)
                    );
                }
                else
                {
                    alColorChord = _AudioTexture.Sample(sampler_linear_clamp, float2(maskBand, 24.5 / 64.0)).rgb;
                }
            }
            float volumeColorSrc = audioLinkMask.g;
            if (_ALDecalVolumeColorSource == 1) volumeColorSrc = bilateralVolume;
            if (_ALDecalVolumeColorSource == 2) volumeColorSrc = audioVal;

            float3 volumeColor = float3(0, 0, 0);
            float3 emissionColor = float3(0, 0, 0);
            if (_ALDecalColorMode == 1)
            {
                volumeColor = alColorChord;
                emissionColor = alColorChord * _ALDecalColorChordEmission;
            }
            else
            {
                float3 lowColor = poiThemeColor(poiMods, _ALDecalVolumeColorLow.rgb, _ALDecalVolumeColorLowThemeIndex);
                float3 midColor = poiThemeColor(poiMods, _ALDecalVolumeColorMid.rgb, _ALDecalVolumeColorMidThemeIndex);
                float3 highColor = poiThemeColor(poiMods, _ALDecalVolumeColorHigh.rgb, _ALDecalVolumeColorHighThemeIndex);

                volumeColor = lerp(lowColor, midColor, saturate(volumeColorSrc * 2));
                volumeColor = lerp(volumeColor, highColor, saturate(volumeColorSrc * 2 - 1));

                emissionColor = lerp(lowColor * _ALDecalLowEmission, midColor * _ALDecalMidEmission, saturate(volumeColorSrc * 2));
                emissionColor = lerp(emissionColor, highColor * _ALDecalHighEmission, saturate(volumeColorSrc * 2 - 1));
            }

            
            //poiFragData.baseColor = lerp(poiFragData.baseColor, volumeColor, audioLinkValue);
            #if defined(POI_PASS_BASE) || defined(POI_PASS_ADD)
                poiFragData.emission += emissionColor * audioLinkValue;
                poiFragData.baseColor.rgb = lerp(poiFragData.baseColor, customBlend(poiFragData.baseColor, volumeColor * colorAndMask.rgb, _ALDecalBlendType), saturate(_ALDecalBlendAlpha * audioLinkValue));
                if (debugBorder)
                {
                    poiFragData.baseColor.rgb = float3(0, 1, 0);
                    poiFragData.emission += float3(0, 1, 0);
                }
                poiFragData.alpha = lerp(poiFragData.alpha, poiFragData.alpha * audioLinkValue, _ALDecalControlsAlpha);
            #endif
        }
    #endif
#endif
//endex
