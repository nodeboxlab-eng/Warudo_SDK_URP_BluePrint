#T#PoiTriplanarProjectionFunctions
//ifex _TriplanarProjection==0
#ifdef TRIPLANAR_PROJECTION
void applyTriplanarProjection(inout PoiFragData poiFragData, inout PoiMesh poiMesh, in PoiCam poiCam)
{
    if (_TriplanarType == 1 && !DepthTextureExists()) return;

    float3 objWorldPos = unity_ObjectToWorld._m03_m13_m23;
    float3 objScale = float3(
        length(unity_ObjectToWorld._m00_m10_m20),
        length(unity_ObjectToWorld._m01_m11_m21),
        length(unity_ObjectToWorld._m02_m12_m22)
    );

    float3 posOS;
    float3 normalWS;
    float distFade = 1.0;
    switch ((int)_TriplanarType)
    {
        default:
        case 1:
        {
            float3 eyeCamPos = getCameraPosition(false);
            float perspectiveDivide = 1.0f / poiCam.clipPos.w;
            float4 direction = float4(poiMesh.worldPos.xyz - eyeCamPos, poiCam.worldDirection.w) * perspectiveDivide;
            float2 screenPos = poiCam.posScreenSpace * perspectiveDivide;
            float rawDepth = SampleScreenDepth(screenPos);
            float sceneEyeDepth = CorrectedLinearEyeDepth(rawDepth, direction.w);
            float fragEyeDepth = CorrectedLinearEyeDepth(poiCam.clipPos.z / poiCam.clipPos.w, direction.w);
            float3 sceneWorldPos = direction.xyz * sceneEyeDepth + eyeCamPos;
            posOS = (sceneWorldPos - objWorldPos) / objScale;
            float dist = length(posOS);
            clip(_TriplanarMaxSize - dist);
            distFade = 1.0 - smoothstep(_TriplanarMaxSize - (_TriplanarEdgeFade.y - _TriplanarEdgeFade.x), _TriplanarMaxSize, dist);
            normalWS = -normalize(cross(ddx(sceneWorldPos), ddy(sceneWorldPos)));
            break;
        }
        case 2:
        {
            posOS = poiMesh.localPos;
            normalWS = poiMesh.objNormal;
            break;
        }
    }

    float mask = 1;
    #if defined(PROP_TRIPLANARMASK) || !defined(OPTIMIZER_ENABLED)
        mask = POI2D_SAMPLER_PAN(_TriplanarMask, _MainTex, poiUV(poiMesh.uv[_TriplanarMaskUV], _TriplanarMask_ST), _TriplanarMaskPan).r;
        mask = (_TriplanarMaskInvert > 0.5) ? 1 - mask : mask;
    #endif

    float3 triblend;
    switch ((int)_TriplanarBlendType)
    {
        default:
        case 3: // Normal blend
        {
            triblend = abs(normalWS);
            triblend = max(triblend - _TriplanarBlendSharpeness, 0);
            triblend /= dot(triblend, float3(1,1,1));
            break;
        }
        case 1: // GPU Gems 3
        {
            triblend = saturate(pow(normalWS, 6));
            triblend /= max(dot(triblend, 1..xxx), 0.0001);
            break;
        }
        case 2: // Asymmetric
        {
            triblend = 0;
            // Blend for sides only
            float2 xzBlend = abs(normalize(normalWS.xz));
            triblend.xz = max(0, xzBlend - 0.67);
            triblend.xz /= max(0.00001, dot(triblend.xz, float2(1,1)));
            // Blend for top
            triblend.y = saturate((abs(normalWS.y) - 0.675) * 80.0);
            triblend.xz *= (1 - triblend.y);
            break;
        }
    }

    #if defined(PROP_TRIPLANARTEXTURE) || !defined(OPTIMIZER_ENABLED)
        float2 uvX = poiUV((posOS.zy + 0.5), _TriplanarTexture_ST);
        float2 uvY = poiUV((posOS.xz + 0.5), _TriplanarTexture_ST);
        float2 uvZ = poiUV((posOS.xy + 0.5), _TriplanarTexture_ST);
    #else
        float2 uvX = (posOS.zy + 0.5);
        float2 uvY = (posOS.xz + 0.5);
        float2 uvZ = (posOS.xy + 0.5);
    #endif

    #if defined(PROP_TRIPLANARNORMAL) || !defined(OPTIMIZER_ENABLED)
        float2 uvNX = poiUV((posOS.zy + 0.5), _TriplanarNormal_ST);
        float2 uvNY = poiUV((posOS.xz + 0.5), _TriplanarNormal_ST);
        float2 uvNZ = poiUV((posOS.xy + 0.5), _TriplanarNormal_ST);
    #else
        float2 uvNX = (posOS.zy + 0.5);
        float2 uvNY = (posOS.xz + 0.5);
        float2 uvNZ = (posOS.xy + 0.5);
    #endif
    
    float3 axisSign = normalWS < 0 ? -1 : 1;
    
    uvX.x *= axisSign.x;
    uvY.x *= axisSign.y;
    uvZ.x *= -axisSign.z;

    float4 colX = float4(0, 0, 0, 0);
    float4 colY = float4(0, 0, 0, 0);
    float4 colZ = float4(0, 0, 0, 0);
    #if defined(PROP_TRIPLANARTEXTURE) || !defined(OPTIMIZER_ENABLED)
        colX = POI2D_SAMPLER_PAN(_TriplanarTexture, _MainTex, uvX, _TriplanarTexturePan);
        colY = POI2D_SAMPLER_PAN(_TriplanarTexture, _MainTex, uvY, _TriplanarTexturePan);
        colZ = POI2D_SAMPLER_PAN(_TriplanarTexture, _MainTex, uvZ, _TriplanarTexturePan);
    #endif

    float4 col = colX * triblend.x + colY * triblend.y + colZ * triblend.z;

    float3 tnormalX = float3(0, 0, 1);
    float3 tnormalY = float3(0, 0, 1);
    float3 tnormalZ = float3(0, 0, 1);
    #if defined(PROP_TRIPLANARNORMAL) || !defined(OPTIMIZER_ENABLED)
        tnormalX = PoiUnpackNormalScale(POI2D_SAMPLER_PAN_STOCHASTIC(_TriplanarNormal, _MainTex, uvNX, _TriplanarNormalPan, _TriplanarNormalStochastic), _TriplanarNormalScale);
        tnormalY = PoiUnpackNormalScale(POI2D_SAMPLER_PAN_STOCHASTIC(_TriplanarNormal, _MainTex, uvNY, _TriplanarNormalPan, _TriplanarNormalStochastic), _TriplanarNormalScale);
        tnormalZ = PoiUnpackNormalScale(POI2D_SAMPLER_PAN_STOCHASTIC(_TriplanarNormal, _MainTex, uvNZ, _TriplanarNormalPan, _TriplanarNormalStochastic), _TriplanarNormalScale);
    #endif

    tnormalX.x *= axisSign.x;
    tnormalY.x *= axisSign.y;
    tnormalZ.x *= -axisSign.z;

    float3 normalX = float3(0.0, tnormalX.yx);
    float3 normalY = float3(tnormalY.x, 0.0, tnormalY.y);
    float3 normalZ = float3(tnormalZ.xy, 0.0);

    normalWS = normalize(
        normalX.xyz * triblend.x +
        normalY.xyz * triblend.y +
        normalZ.xyz * triblend.z +
        normalWS
        );

    if (_TriplanarType == 1)
    {
        float camDist = distance(getCameraPosition(true), objWorldPos);
        float worldMaxSize = _TriplanarMaxSize * max(objScale.x, max(objScale.y, objScale.z));
        float camProximity = saturate(camDist / worldMaxSize);
        float camFade = 1.0 - smoothstep(_TriplanarCameraFade.x, _TriplanarCameraFade.y, camProximity);

        distFade *= camFade;
        
        poiMesh.localPos = posOS;
        poiMesh.worldPos = mul(unity_ObjectToWorld, float4(posOS, 1)).xyz;
    }

    col.a *= distFade;

    poiFragData.baseColor = lerp(poiFragData.baseColor, col.rgb, mask);
    poiFragData.alpha = lerp(poiFragData.alpha, col.a, mask);
    poiMesh.normals[1] = lerp(poiMesh.normals[1], normalWS, mask);
}
#endif
//endex

