        float3 PoiConstellationHSVtoRGB(float3 hsv)
        {
            float h = hsv.x * 6.0;
            float s = hsv.y;
            float v = hsv.z;
            
            float c = v * s;
            float x = c * (1.0 - abs(fmod(h, 2.0) - 1.0));
            float m = v - c;
            
            float3 rgb;
            if(h < 1.0) rgb = float3(c, x, 0);
            else if(h < 2.0) rgb = float3(x, c, 0);
            else if(h < 3.0) rgb = float3(0, c, x);
            else if(h < 4.0) rgb = float3(0, x, c);
            else if(h < 5.0) rgb = float3(x, 0, c);
            else rgb = float3(c, 0, x);
            
            return rgb + m;
        }

        float3 PoiConstellationRGBtoHSV(float3 rgb)
        {
            float cmax = max(rgb.r, max(rgb.g, rgb.b));
            float cmin = min(rgb.r, min(rgb.g, rgb.b));
            float delta = cmax - cmin;
            
            float h = 0;
            if(delta > 0.0001)
            {
                if(cmax == rgb.r) h = fmod((rgb.g - rgb.b) / delta, 6.0);
                else if(cmax == rgb.g) h = (rgb.b - rgb.r) / delta + 2.0;
                else h = (rgb.r - rgb.g) / delta + 4.0;
                h /= 6.0;
                if(h < 0) h += 1.0;
            }
            
            float s = (cmax > 0.0001) ? delta / cmax : 0;
            float v = cmax;
            
            return float3(h, s, v);
        }

        float3 PoiGetStarColor(float2 cellId, float hueShift, float3 themeColor, bool useThemeColor)
        {
            float rand1 = frac(sin(dot(cellId, float2(127.1, 311.7))) * 43758.5453);
            float rand2 = frac(sin(dot(cellId, float2(269.5, 183.3))) * 43758.5453);
            float rand3 = frac(sin(dot(cellId, float2(419.2, 371.9))) * 43758.5453);
            
            if(useThemeColor)
            {
                // Use theme color with slight random variation in saturation/value
                float3 themeHSV = PoiConstellationRGBtoHSV(themeColor);
                themeHSV.x = frac(themeHSV.x + (rand1 - 0.5) * 0.1); // Slight hue variation
                themeHSV.y = saturate(themeHSV.y * lerp(0.8, 1.2, rand2)); // Slight saturation variation
                themeHSV.z = saturate(themeHSV.z * lerp(0.8, 1.2, rand3)); // Slight value variation
                return PoiConstellationHSVtoRGB(themeHSV);
            }
            
            float3 hsv;
            hsv.x = frac(rand1 + hueShift);
            hsv.y = lerp(_ConstellationSaturationRange.x, _ConstellationSaturationRange.y, rand2);
            hsv.z = lerp(_ConstellationValueRange.x, _ConstellationValueRange.y, rand3);
            
            return PoiConstellationHSVtoRGB(hsv);
        }

        float PoiDistLine(float2 p, float2 a, float2 b)
        {
            float2 pa = p-a;
            float2 ba = b-a;
            float t = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
            return length(pa - ba * t);
        }

        float PoiLine(float2 p, float2 a, float2 b, float thicknessMod)
        {
            float2 pa = p-a;
            float2 ba = b-a;
            float t = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
            float d = length(pa - ba * t);
            float lineLength = length(a-b);
            float finalThickness = saturate(_ConstellationLineThickness + thicknessMod);
            float baseThickness = lerp(0.005, 0.05, finalThickness);
            float centerThinness = 4.0 * t * (1.0 - t);
            float minThickness = lerp(baseThickness, baseThickness * 0.3, _ConstellationLineThicknessVariation);
            float thickness = lerp(minThickness, baseThickness, 1.0 - centerThinness);
            
            float lineFade = 1.0 - smoothstep(0.0, thickness, d);
            float lengthFade = smoothstep(1.2, 0.05, lineLength);
            
            return lineFade * lengthFade;
        }

        float4 PoiLineColored(float2 p, float2 a, float2 b, float3 colorA, float3 colorB, float thicknessMod)
        {
            float2 pa = p-a;
            float2 ba = b-a;
            float t = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
            float d = length(pa - ba * t);
            float lineLength = length(a-b);
            float finalThickness = saturate(_ConstellationLineThickness + thicknessMod);
            float baseThickness = lerp(0.005, 0.05, finalThickness);
            float centerThinness = 4.0 * t * (1.0 - t);
            float minThickness = lerp(baseThickness, baseThickness * 0.3, _ConstellationLineThicknessVariation);
            float thickness = lerp(minThickness, baseThickness, 1.0 - centerThinness);
            
            float lineFade = 1.0 - smoothstep(0.0, thickness, d);
            float lengthFade = smoothstep(1.2, 0.05, lineLength);
            
            float intensity = lineFade * lengthFade;
            float3 blendedColor = lerp(colorA, colorB, t);
            
            return float4(blendedColor, intensity);
        }

        float PoiN21(float2 p)
        {
            float3 p3 = frac(float3(p.xyx) * float3(0.1031, 0.1030, 0.0973));
            p3 += dot(p3, p3.yzx + 33.33);
            return frac((p3.x + p3.y) * p3.z);
        }

        float2 PoiN22(float2 p)
        {
            float n = PoiN21(p);
            return float2(n, PoiN21(p+n));
        }

        float2 PoiGetPos(float2 id, float2 off, float time, float movementMod)
        {
            float2 n = PoiN22(id + off) * (time + movementMod);
            return off + sin(n) * _ConstellationStarMovement;
        }

        float PoiLayer(float2 uv, float time, float sizeMod, float brightnessMod, float twinkleMod, float movementMod, float lineThicknessMod, float lineBrightnessMod)
        {
            float2 gv = frac(uv) - 0.5;
            float2 id = floor(uv);
            float lines = 0.0;
            float sparkles = 0.0;

            float2 p[9];
            int i = 0;
            
            float t = time * _ConstellationStarSpeedMultiplier;
            for(float y=-1.0;y<=1.0;y++){
                for(float x=-1.0;x<=1.0;x++){
                    p[i++] = PoiGetPos(id, float2(x, y), t, movementMod);
                }
            }
            
            t = time * _ConstellationTwinkleSpeed + twinkleMod;
            
            float starSize = saturate(_ConstellationStarSize + sizeMod);
            float starBrightness = max(0, _ConstellationStarBrightness + brightnessMod);
            
            float sizeScale = (1-starSize*0.75);
            
            for(int j = 0; j < 9; j++)
            {
                lines += PoiLine(gv, p[4], p[j], lineThicknessMod);
                
                float2 vec = (p[j] - gv) * 30.0 * sizeScale;
                float sparkle = 1.0/max(dot(vec, vec), 0.01);
                sparkle = min(sparkle, 5.0);
                
                sparkles += sparkle*(sin(t+frac(p[j].x)*10.0)*0.5 + 0.5);
            }
            
            lines += PoiLine(gv, p[1], p[3], lineThicknessMod);
            lines += PoiLine(gv, p[1], p[5], lineThicknessMod);
            lines += PoiLine(gv, p[3], p[7], lineThicknessMod);
            lines += PoiLine(gv, p[5], p[7], lineThicknessMod);
            
            float finalLineBrightness = max(0, _ConstellationLineBrightness + lineBrightnessMod);
            lines = min(lines * finalLineBrightness, 1.0);
            sparkles = min(sparkles * starBrightness / 4.0, 1.0);
            
            return min(lines + sparkles, 1.0);
        }

        float4 PoiLayerColored(float2 uv, float time, float sizeMod, float brightnessMod, float twinkleMod, float movementMod, float lineThicknessMod, float lineBrightnessMod, float hueShift, float3 themeColor, bool useThemeColor)
        {
            float2 gv = frac(uv) - 0.5;
            float2 id = floor(uv);
            float3 lineColor = float3(0, 0, 0);
            float lineIntensity = 0.0;
            float3 sparkleColor = float3(0, 0, 0);
            float sparkleIntensity = 0.0;

            float2 p[9];
            float2 cellIds[9];
            float3 starColors[9];
            int i = 0;
            
            float t = time * _ConstellationStarSpeedMultiplier;

            for(float y=-1.0;y<=1.0;y++){
                for(float x=-1.0;x<=1.0;x++){
                    p[i] = PoiGetPos(id, float2(x, y), t, movementMod);
                    cellIds[i] = id + float2(x, y);
                    starColors[i] = PoiGetStarColor(cellIds[i], hueShift, themeColor, useThemeColor);
                    i++;
                }
            }
            
            t = time * _ConstellationTwinkleSpeed + twinkleMod;
            
            float starSize = saturate(_ConstellationStarSize + sizeMod);
            float starBrightness = max(0, _ConstellationStarBrightness + brightnessMod);
            
            float sizeScale = (1-starSize*0.75);
            
            // Pre-calculate twinkle factor for each star
            float twinkle[9];
            for(int k = 0; k < 9; k++)
            {
                twinkle[k] = sin(t+frac(p[k].x)*10.0)*0.5 + 0.5;
            }
            
            for(int j = 0; j < 9; j++)
            {
                // Lines use average twinkle of both endpoints
                float lineTwinkle = (twinkle[4] + twinkle[j]) * 0.5;
                float4 lineResult = PoiLineColored(gv, p[4], p[j], starColors[4], starColors[j], lineThicknessMod);
                lineColor += lineResult.rgb * lineResult.a * lineTwinkle;
                lineIntensity += lineResult.a * lineTwinkle;
                
                float2 vec = (p[j] - gv) * 30.0 * sizeScale;
                float sparkle = 1.0/max(dot(vec, vec), 0.01);
                sparkle = min(sparkle, 5.0);
                sparkle *= twinkle[j];
                
                sparkleColor += starColors[j] * sparkle;
                sparkleIntensity += sparkle;
            }
            
            // Additional lines with twinkle
            float twinkle13 = (twinkle[1] + twinkle[3]) * 0.5;
            float twinkle15 = (twinkle[1] + twinkle[5]) * 0.5;
            float twinkle37 = (twinkle[3] + twinkle[7]) * 0.5;
            float twinkle57 = (twinkle[5] + twinkle[7]) * 0.5;
            
            float4 lineResult1 = PoiLineColored(gv, p[1], p[3], starColors[1], starColors[3], lineThicknessMod);
            float4 lineResult2 = PoiLineColored(gv, p[1], p[5], starColors[1], starColors[5], lineThicknessMod);
            float4 lineResult3 = PoiLineColored(gv, p[3], p[7], starColors[3], starColors[7], lineThicknessMod);
            float4 lineResult4 = PoiLineColored(gv, p[5], p[7], starColors[5], starColors[7], lineThicknessMod);
            
            lineColor += lineResult1.rgb * lineResult1.a * twinkle13;
            lineColor += lineResult2.rgb * lineResult2.a * twinkle15;
            lineColor += lineResult3.rgb * lineResult3.a * twinkle37;
            lineColor += lineResult4.rgb * lineResult4.a * twinkle57;
            lineIntensity += lineResult1.a * twinkle13 + lineResult2.a * twinkle15 + lineResult3.a * twinkle37 + lineResult4.a * twinkle57;
            
            float finalLineBrightness = max(0, _ConstellationLineBrightness + lineBrightnessMod);
            lineIntensity = min(lineIntensity * finalLineBrightness, 1.0);
            sparkleIntensity = min(sparkleIntensity * starBrightness / 4.0, 1.0);
            
            float totalIntensity = min(lineIntensity + sparkleIntensity, 1.0);
            float3 finalColor = float3(0, 0, 0);
            if(totalIntensity > 0.001)
            {
                finalColor = (lineColor * finalLineBrightness + sparkleColor * starBrightness / 4.0) / (lineIntensity + sparkleIntensity + 0.001);
            }
            
            return float4(finalColor, totalIntensity);
        }

        void applyConstellation(inout PoiFragData poiFragData, in PoiMesh poiMesh, in PoiMods poiMods)
        {
            if(_ConstellationEnable == 0) return;

            float4 constellationColorFinal = _ConstellationColor;
            if(_ConstellationColorThemeIndex > 0)
            {
                constellationColorFinal.rgb = poiThemeColor(poiMods, _ConstellationColor.rgb, _ConstellationColorThemeIndex);
            }

            float mask = 1.0;
            #if defined(PROP_CONSTELLATIONMASK) || !defined(OPTIMIZER_ENABLED)
                mask = POI2D_SAMPLER_PAN(_ConstellationMask, _MainTex, poiUV(poiMesh.uv[_ConstellationMaskUV], _ConstellationMask_ST), _ConstellationMaskPan).r;
            #endif
            if(_ConstellationMaskInvert) 
            {
                mask = 1.0 - mask;
            }
            
            if(_ConstellationMaskGlobalMask > 0)
            {
                mask = maskBlend(mask, poiMods.globalMask[_ConstellationMaskGlobalMask - 1], _ConstellationMaskGlobalMaskBlendType);
            }
            
            if(mask == 0.0) 
            {
                return;
            }

            float alEmissionMod = 0;
            float alBrightnessMod = 0;
            float alSizeMod = 0;
            float alLineThicknessMod = 0;
            float alLineBrightnessMod = 0;
            float alTwinkleMod = 0;
            float alMovementMod = 0;
            float alHueShift = 0;
            float3 alThemeColor = float3(1, 1, 1);
            bool alUseThemeColor = false;
            
            #ifdef POI_AUDIOLINK
                if(AudioLinkIsAvailable() && _ConstellationAudioLinkEnabled)
                {
                    // Intensity-reactive modifiers
                    alEmissionMod = lerp(_ConstellationALEmissionMod.x, _ConstellationALEmissionMod.y, poiMods.audioLink[_ConstellationALEmissionBand]);
                    alBrightnessMod = lerp(_ConstellationALBrightnessMod.x, _ConstellationALBrightnessMod.y, poiMods.audioLink[_ConstellationALBrightnessBand]);
                    alSizeMod = lerp(_ConstellationALSizeMod.x, _ConstellationALSizeMod.y, poiMods.audioLink[_ConstellationALSizeBand]);
                    alLineThicknessMod = lerp(_ConstellationALLineThicknessMod.x, _ConstellationALLineThicknessMod.y, poiMods.audioLink[_ConstellationALLineThicknessBand]);
                    alLineBrightnessMod = lerp(_ConstellationALLineBrightnessMod.x, _ConstellationALLineBrightnessMod.y, poiMods.audioLink[_ConstellationALLineBrightnessBand]);
                    
                    // Chronotensity-based modifiers
                    alTwinkleMod = AudioLinkGetChronoTime(_ConstellationALTwinkleType, _ConstellationALTwinkleBand) * _ConstellationALTwinkleSpeed;
                    alMovementMod = AudioLinkGetChronoTime(_ConstellationALMovementType, _ConstellationALMovementBand) * _ConstellationALMovementSpeed;
                    
                    // Color modifiers (only used when random colors enabled)
                    if(_ConstellationRandomColors)
                    {
                        alHueShift = AudioLinkGetChronoTime(_ConstellationALHueShiftType, _ConstellationALHueShiftBand) * _ConstellationALHueShiftSpeed;
                        if(_ConstellationALThemeColor > 0)
                        {
                            alUseThemeColor = true;
                            alThemeColor = AudioLinkData(ALPASS_THEME_COLOR0 + uint2(_ConstellationALThemeColor - 1, 0)).rgb;
                        }
                    }
                }
            #endif

            float2 uv = poiMesh.uv[_ConstellationUV].xy - _ConstellationCenter;
            uv *= _ConstellationDensity;
            
            float t = POI_TIME.y * _ConstellationPanSpeed.z / _ConstellationDensity + _ConstellationOffset.z;
            
            uv += (_ConstellationPanSpeed.xy / _ConstellationDensity) * POI_TIME.y + _ConstellationOffset.xy;
            
            float constellationMask = 0.0;
            float3 constellationColor = float3(0, 0, 0);
            
            UNITY_BRANCH
            if(_ConstellationRandomColors)
            {
                float3 accumulatedColor = float3(0, 0, 0);
                float accumulatedIntensity = 0.0;
                
                for(float i=0.0;i<1.0;i+= 1.0/4.0)
                {
                    float z = frac(i+t);
                    float size = lerp(10.0, 0.5, z);
                    // Fade based on layer depth: z=0 is back (use min), z=1 is front (use max)
                    float fade = lerp(_ConstellationLayerFade.x, _ConstellationLayerFade.y, z);
                    
                    float4 layerResult = PoiLayerColored(uv * size + i*24.0, POI_TIME.y, alSizeMod, alBrightnessMod, alTwinkleMod, alMovementMod, alLineThicknessMod, alLineBrightnessMod, alHueShift, alThemeColor, alUseThemeColor);
                    accumulatedColor += layerResult.rgb * layerResult.a * fade;
                    accumulatedIntensity += layerResult.a * fade;
                }
                
                constellationMask = min(accumulatedIntensity, 1.0) * mask;
                if(accumulatedIntensity > 0.001)
                {
                    constellationColor = accumulatedColor / accumulatedIntensity * constellationMask;
                }
            }
            else
            {
                float m = 0.0;
                for(float i=0.0;i<1.0;i+= 1.0/4.0)
                {
                    float z = frac(i+t);
                    float size = lerp(10.0, 0.5, z);
                    // Fade based on layer depth: z=0 is back (use min), z=1 is front (use max)
                    float fade = lerp(_ConstellationLayerFade.x, _ConstellationLayerFade.y, z);
                    
                    m += PoiLayer(uv * size + i*24.0, POI_TIME.y, alSizeMod, alBrightnessMod, alTwinkleMod, alMovementMod, alLineThicknessMod, alLineBrightnessMod) * fade;
                }
                
                m = min(m, 1.0);
                m *= mask;
                constellationMask = m;
                constellationColor = m * constellationColorFinal.rgb;
            }
            
            #ifdef POI_AUDIOLINK
                if(AudioLinkIsAvailable() && _ConstellationAudioLinkEnabled)
                {
                    if (_ConstellationALColorOverrideEnabled)
                    {
                        float alColorOverrideIntensity = poiMods.audioLink[_ConstellationALColorOverrideBand];
                        float alColorOverrideBlend = evalRamp4(alColorOverrideIntensity, _ConstellationALColorOverrideRamp);
                        if(alColorOverrideBlend > 0)
                        {
                            float3 alOverrideColor = _ConstellationALColorOverride.rgb;
                            if(_ConstellationALColorOverrideThemeIndex > 0)
                            {
                                alOverrideColor = poiThemeColor(poiMods, alOverrideColor, _ConstellationALColorOverrideThemeIndex);
                            }
                            constellationColor = lerp(constellationColor, alOverrideColor * constellationMask, alColorOverrideBlend);
                        }
                    }
                }
            #endif

            if(_ConstellationBlendMode == 0)
            {
                poiFragData.baseColor = lerp(poiFragData.baseColor, constellationColor, constellationMask);
            }
            else if(_ConstellationBlendMode == 1)
            {
                poiFragData.baseColor = lerp(poiFragData.baseColor, poiFragData.baseColor * constellationColor, constellationMask);
            }
            else
            {
                poiFragData.baseColor += constellationColor * constellationMask;
            }
            
            float finalEmissionStrength = _ConstellationEmissionStrength + alEmissionMod;
            poiFragData.emission += constellationColor * constellationMask * finalEmissionStrength;
            
            if(_ConstellationApplyGlobalMaskIndex > 0)
            {
                applyToGlobalMask(poiMods, _ConstellationApplyGlobalMaskIndex - 1, _ConstellationApplyGlobalMaskBlendType, constellationMask);
            }
        }
    #endif
//endex

#T#PoiConstellationFunctionCall
//ifex _ConstellationEnable==0
    #ifdef POI_CONSTELLATION
        applyConstellation(poiFragData, poiMesh, poiMods);
    #endif
//endex