#T#PoiSquishFragmentFunction
//ifex _EnableSquish==0
#ifdef POI_SQUISH
void applyPoiSquishColor(in VertexOut i, inout PoiFragData poiFragData, inout PoiLight poiLight, inout PoiMods poiMods)
{
    if (_SquishEnabled >= 0.5)
    {
        float4 squishGradient;
        #if defined(PROP_SQUISHGRADIENT) || !defined(OPTIMIZER_ENABLED)
            squishGradient = UNITY_SAMPLE_TEX2D_SAMPLER(_SquishGradient, _linear_clamp, poiUV(float2(saturate(1.0 - i.squishAmount), 0.5), _SquishGradient_ST));
        #else
            squishGradient = float4(0, 0, 0, 1);
        #endif

        i.squishAmount *= _SquishGradientIntensity;
        squishGradient *= i.squishAmount;

        poiFragData.baseColor.rgb = lerp(poiFragData.baseColor.rgb, squishGradient.rgb, _SquishReplace * squishGradient.a * .999999);
        poiFragData.baseColor.rgb *= lerp(1, squishGradient.rgb, _SquishMultiply * squishGradient.a);
        #if defined(POI_PASS_BASE) || defined(POI_PASS_OUTLINE)
            poiLight.finalLightAdd += squishGradient.rgb * _SquishAddToLight * squishGradient.a;
        #endif
        
        if (_SquishApplyGlobalMaskIndex > 0)
        {
            applyToGlobalMask(poiMods, _SquishApplyGlobalMaskIndex - 1, _SquishApplyGlobalMaskBlendType, squishGradient.r);
        }
    }
}
#endif
//endex

#T#PoiSquishFragmentFunctionCalls
//ifex _EnableSquish==0
#if defined(POI_SQUISH) && (defined(POI_PASS_BASE) || defined(POI_PASS_ADD) || defined(POI_PASS_OUTLINE))
    applyPoiSquishColor(i, poiFragData, poiLight, poiMods);
