#T#PoiSquishVertexFunctions
//ifex _EnableSquish==0
#ifdef POI_SQUISH
void GetVertexLights(inout float3 positionOS, inout float3 normalOS)
{
    positionOS = 1e20;
    normalOS = float3(0, 0, 1);

    #if POI_PIPE == POI_BIRP
    // SPS-compatible light detection (matches VRCFury SPS socket protocol)
    // Light range second decimal: 1 = hole root, 2 = ring root, 5 = front/normal
    int lightClass[4];    // 0 = invalid, 1 = root (hole/ring), 2 = front
    float3 lightWS[4];
    float3 lightOS[4];

    for (int i = 0; i < 4; i++)
    {
        lightClass[i] = 0;
        float range = 5.0 / sqrt(unity_4LightAtten0[i]);
        lightWS[i] = float3(unity_4LightPosX0[i], unity_4LightPosY0[i], unity_4LightPosZ0[i]);
        lightOS[i] = mul(unity_WorldToObject, float4(lightWS[i], 1.)).xyz;

        if (range >= 0.5 || length(unity_LightColor[i].rgb) > 0.01)
            continue;

        int secondDecimal = round(fmod(range, 0.1) * 100);
        if (secondDecimal == 1 || secondDecimal == 2) lightClass[i] = 1;
        else if (secondDecimal == 5) lightClass[i] = 2;
    }

    // Find nearest root light (hole or ring socket position)
    int rootIdx = 0;
    bool rootFound = false;
    float minRootDist = 1e20;
    for (int r = 0; r < 4; r++)
    {
        if (lightClass[r] != 1) continue;
        float d = length(lightOS[r]);
        if (d < minRootDist)
        {
            rootFound = true;
            rootIdx = r;
            minRootDist = d;
        }
    }

    if (!rootFound) return;

    positionOS = lightOS[rootIdx];

    // Find front light closest to the root (within 0.1m world-space)
    int frontIdx = 0;
    bool frontFound = false;
    float minFrontDist = 0.1;
    for (int f = 0; f < 4; f++)
    {
        if (lightClass[f] != 2) continue;
        float d = length(lightWS[f] - lightWS[rootIdx]);
        if (d < minFrontDist)
        {
            frontFound = true;
            frontIdx = f;
            minFrontDist = d;
        }
    }

    // Ignore front light if too close to root (rounding error)
    if (frontFound && length(lightOS[frontIdx] - lightOS[rootIdx]) < 0.00005)
        frontFound = false;

    // Compute squish plane normal (inward-facing)
    if (frontFound)
    {
        normalOS = -normalize(lightOS[frontIdx] - lightOS[rootIdx]);
    }
    else
    {
        float len = length(lightOS[rootIdx]);
        normalOS = len > 0.00001 ? -lightOS[rootIdx] / len : float3(0, 0, -1);
    }
    #endif
}

bPlane createBoundedPlane(float3 center, float3 normal, float3 up, float2 size)
{
    bPlane plane;
    plane.center = center;
    plane.normal = normal;
    plane.tangent = normalize(cross(up, plane.normal));
    plane.bitangent = cross(plane.normal, plane.tangent);
    plane.halfExtents = size * 0.5;
    
    return plane;
}

float2 distBoundedPlane(bPlane plane, float3 positionOS)
{
    float3 toPoint = positionOS - plane.center;

    float u = dot(toPoint, plane.tangent);
    float v = dot(toPoint, plane.bitangent);
    float distToPlane = dot(toPoint, plane.normal);

    if (abs(u) > plane.halfExtents.x || abs(v) > plane.halfExtents.y)
        return float2(1e20, 1e20);

    float distLeft   = -plane.halfExtents.x - u;
    float distRight  = u - plane.halfExtents.x;
    float distBottom = -plane.halfExtents.y - v;
    float distTop    = v - plane.halfExtents.y;
    float distToEdge = max(max(distLeft, distRight), max(distBottom, distTop));

    return float2(distToPlane, distToEdge);
}

#ifdef POI_PASS_LILFUR
void applyPoiSquish(inout appdata v, inout PoiVertToGeoLilFur o)
#else
void applyPoiSquish(inout appdata v, inout VertexOut o)
#endif
{
    if (_SquishEnabled < 0.5) return;

    float squishMask = 1.0;
    #if defined(PROP_SQUISHMASK) || !defined(OPTIMIZER_ENABLED)
        squishMask = UNITY_SAMPLE_TEX2D_SAMPLER_LOD(_SquishMask, _linear_repeat, poiUV(vertexUV(o, _SquishMaskUV), _SquishMask_ST), 0)[_SquishMaskChannel];
    #endif
    if (_SquishMaskInvert)
    {
        squishMask = 1.0 - squishMask;
    }
    if (squishMask <= 0.0) return;

    float3 squishNormalOS;
    float3 squishOriginOS;
    GetVertexLights(squishOriginOS, squishNormalOS);

    if (distance(v.vertex.xyz, squishOriginOS) > 1.0) return;

    float3 upOS =  mul((float3x3)unity_WorldToObject, float3(0, 1, 0)).xyz;
    bPlane squishPlane = createBoundedPlane(squishOriginOS, squishNormalOS, upOS, _SquishPlaneSize.xy);

    float2 dist = distBoundedPlane(squishPlane, v.vertex.xyz);
    
    const float startSquish = 0.01;
    if (dist.x < startSquish)
    {
        float3 posOS = v.vertex.xyz;
        float3 normalOS = v.normal;
        float3 tangentOS = v.tangent.xyz;

        float falloff = smoothstep(0.0, 1.0, -dist.y / clamp(_SquishFalloff, 0.01, 1.0));
        falloff *= smoothstep(1.0, 0.0, abs(dist.x));
        float squishCurve = ((startSquish - dist.x) / clamp(1.0 - _SquishStrength, 0.01, 1.0));
        float squishAmount = min(smoothstep(0.0, 1.0, squishCurve * falloff * squishMask), _SquishMax);

        float flipNormal = sign(dot(v.normal, -squishPlane.normal));
        float3 targetNormal = -squishPlane.normal * flipNormal;
        normalOS = normalize(lerp(normalOS, targetNormal, squishAmount));
        tangentOS = normalize(tangentOS - normalOS * dot(tangentOS, normalOS));

        float3 projected = posOS - squishPlane.normal * dist.x;
        float3 center = posOS - squishPlane.center;
        float uu = dot(center, squishPlane.tangent);
        float vv = dot(center, squishPlane.bitangent);
        float3 spreadDir = Unity_SafeNormalize(uu * squishPlane.tangent + vv * squishPlane.bitangent);
        float bumpCurve = exp(-pow((squishAmount - 0.333) / 0.85, 2));
        projected += spreadDir * max(bumpCurve * 0.04, squishAmount * 0.02) * _SquishSpread;

        posOS = lerp(posOS, projected, squishAmount);
        
        float depthOrder = dist.x * squishAmount * -_SquishClipOffset;
        float3 viewDirOS = normalize(PoiObjSpaceViewDir(float4(posOS, 1)));
        posOS += viewDirOS * depthOrder;

        float3 squishDir = Unity_SafeNormalize(v.vertex.xyz - posOS);
        o.squishAmount = smoothstep(_SquishGradientMin, _SquishGradientMax, squishAmount + dot(squishDir, v.normal));

        v.vertex.xyz = posOS;
        v.normal = normalOS;
        v.tangent.xyz = tangentOS;
        v.tangent.w = v.tangent.w * flipNormal;
    }
}
#endif
//endex

