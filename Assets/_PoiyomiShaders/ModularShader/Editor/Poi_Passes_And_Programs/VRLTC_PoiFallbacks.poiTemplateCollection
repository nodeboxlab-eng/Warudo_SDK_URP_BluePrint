#T#PoiGeomQuestFallback
// Meta quest fallback for geometry shaders
#if defined(POI_DEVICE_QUEST)
    [unroll(2)]
    for (int j = 0; j < 2; j++)
    {
        [unroll(3)]
        for (int i = 0; i < 3; i++)
        {
            #ifdef POI_PASS_LILFUR
                PoiGeoToFragLilFur fallbackOutput;
                PoiInitStruct(PoiGeoToFragLilFur, fallbackOutput);
                SetupFurOutputStructs(fallbackOutput, input, furVectors, float3(0.0, 0.0, 0.0));
            #else
                VertexOut fallbackOutput = input[i];
            #endif
            float4x4 MVP = unity_StereoMatrixVP[j];
            fallbackOutput.pos = mul(MVP, float4(fallbackOutput.worldPos.xyz, 1.0));
            fallbackOutput.gl_Layer = j;
            outStream.Append(fallbackOutput);
        }
        outStream.RestartStrip();
    }
    return;
#endif