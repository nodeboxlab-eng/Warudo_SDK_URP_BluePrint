#T#PoiLilFurVertexProgram
PoiVertToGeoLilFur vert(appdata v)
{
	UNITY_SETUP_INSTANCE_ID(v);
	PoiVertToGeoLilFur o;
	PoiInitStruct(PoiVertToGeoLilFur, o);
	UNITY_TRANSFER_INSTANCE_ID(v, o);

	#ifdef POI_AUDIOLINK
		float vertexAudioLink[5];
		vertexAudioLink[0] = _AudioLinkSmoothingBass == 0 ? AudioLinkData(ALPASS_AUDIOLINK + float2(0, 0))[0] : AudioLinkData(ALPASS_FILTEREDAUDIOLINK + float2((1 - _AudioLinkSmoothingBass) * 15.95, 0))[0];
		vertexAudioLink[1] = _AudioLinkSmoothingLowMid == 0 ? AudioLinkData(ALPASS_AUDIOLINK + float2(0, 1))[0] : AudioLinkData(ALPASS_FILTEREDAUDIOLINK + float2((1 - _AudioLinkSmoothingLowMid) * 15.95, 1))[0];
		vertexAudioLink[2] = _AudioLinkSmoothingHighMid == 0 ? AudioLinkData(ALPASS_AUDIOLINK + float2(0, 2))[0] : AudioLinkData(ALPASS_FILTEREDAUDIOLINK + float2((1 - _AudioLinkSmoothingHighMid) * 15.95, 2))[0];
		vertexAudioLink[3] = _AudioLinkSmoothingTreble == 0 ? AudioLinkData(ALPASS_AUDIOLINK + float2(0, 3))[0] : AudioLinkData(ALPASS_FILTEREDAUDIOLINK + float2((1 - _AudioLinkSmoothingTreble) * 15.95, 3))[0];
		vertexAudioLink[4] = AudioLinkData(ALPASS_GENERALVU + float2(8, 0))[0];
	#endif
	/*
	//ifex _RenderingAOBlockerEnabled==0
	#ifndef POI_PASS_SHADOW
		if (_RenderingAOBlockerEnabled)
		{
			float2 blockerUV = 0;
			blockerUV += (v.uv0.xy * (_RenderingAOBlockerUVChannel == 0));
			blockerUV += (v.uv1.xy * (_RenderingAOBlockerUVChannel == 1));
			blockerUV += (v.uv2.xy * (_RenderingAOBlockerUVChannel == 2));
			blockerUV += (v.uv3.xy * (_RenderingAOBlockerUVChannel == 3));
			if (blockerUV.x < 0 && blockerUV.x > - 1 && blockerUV.y < 1 && blockerUV.y > 0)
			{
				return (PoiVertToGeoLilFur)POI_NAN;
			}
		}
	#endif
	//endex
	*/
	#K#VERTEX_INPUT_MODS

	#if POI_PIPE == POI_BIRP
		o.normal = UnityObjectToWorldNormal(v.normal);
	#elif  POI_PIPE == POI_URP
		VertexNormalInputs vertexNormalInput = GetVertexNormalInputs(v.normal, v.tangent);
		o.normal = vertexNormalInput.normalWS;
	#endif

	o.uv[0] = float4(v.uv0.xy, v.uv1.xy);
	o.uv[1] = float4(v.uv2.xy, v.uv3.xy);
	
	o.vertexId = v.vertexId;

	// #if defined(LIGHTMAP_ON)
	// 	o.lightmapUV.xy = v.uv1.xy * unity_LightmapST.xy + unity_LightmapST.zw;
	// #endif
	// #ifdef DYNAMICLIGHTMAP_ON
	// 	o.lightmapUV.zw = v.uv2.xy * unity_DynamicLightmapST.xy + unity_DynamicLightmapST.zw;
	// #endif

	o.worldPos = mul(unity_ObjectToWorld, v.vertex);

	float3 localOffset = float3(0, 0, 0);
	float3 worldOffset = float3(0, 0, 0);

	#K#VERTEX_MODS_EARLY
	#K#VERTEX_MODS
	#K#VERTEX_MODS_LATE

	v.vertex.rgb += localOffset;
	o.worldPos.rgb += worldOffset;

	#K#VERTEX_MODS_PENETRATION
	#K#VERTEX_MODS_PRE_CLIPPOS

	// Calculate clip space position (need for fog later)
	float4 clipPos = PoiObjectToClipPos(v.vertex);
	o.fogData = clipPos.z;

	#K#VERTEX_MODS_POST_CLIPPOS

	// #ifdef POI_PASS_META
	// 	o.pos = UnityMetaVertexPosition(v.vertex, v.uv1.xy, v.uv2.xy, unity_LightmapST, unity_DynamicLightmapST);
	// #endif

	#ifdef POI_PASS_LILFUR
		// Calculate fur vector
		float3 bitangentOS = normalize(cross(v.normal, v.tangent.xyz)) * (v.tangent.w * length(v.normal));
		float3x3 tbnOS = float3x3(v.tangent.xyz, bitangentOS, v.normal);
		o.furVector = _FurVector.xyz + float3(0, 0, 0.001);
		
		if(_VertexColor2FurVector) o.furVector = float3(o.furVector.xy + (v.color.xyz * 2.0 - 1.0).xy, o.furVector.z * (v.color.xyz * 2.0 - 1.0).z);
		
		#if defined(PROP_FURVECTORTEX) || !defined(OPTIMIZER_ENABLED)
			float2 uvMain = v.uv0.xy * _MainTex_ST.xy + _MainTex_ST.zw;
			float3 furVectorTex = UnpackScaleNormal(_FurVectorTex.SampleLevel(sampler_linear_repeat, uvMain, 0), _FurVectorScale);
			o.furVector = float3(o.furVector.xy + furVectorTex.xy, o.furVector.z * furVectorTex.z);
		#endif
		
		o.furVector = mul(normalize(o.furVector), tbnOS);
		o.furVector *= _FurVector.w;
		
		#ifdef LIL_FUR_PRE
			o.furVector *= _FurCutoutLength;
		#endif
		
		o.furVector = lilTransformDirOStoWS(o.furVector, false);
		float furLength = length(o.furVector);
		o.furVector.y -= _FurGravity * furLength;
		
		
		#K#VERTEX_MODS_LILFUR
	#endif

	#K#VERTEX_MODS_FINAL

	return o;
}

#T#PoiLilFurGeometryProgram
// Helper function for reduce clip distance in geometry shader
void applyReducedRenderClipDistanceGeoFur(inout float4 pos)
{
	//ifex _RenderingReduceClipDistance==0
	if (_RenderingReduceClipDistance)
	{
		if (pos.w < _ProjectionParams.y * 1.01 && pos.w > 0)
		{
			#if defined(UNITY_REVERSED_Z) // DirectX
				pos.z = pos.z * 0.0001 + pos.w * 0.999;
			#else // OpenGL
				pos.z = pos.z * 0.0001 - pos.w * 0.999;
			#endif
		}
	}
	//endex
}

float lilLerpFloat(float a, float b, float c, float3 factor)
{
	return a * factor.x + b * factor.y + c * factor.z;
}
float2 lilLerpFloat2(float2 a, float2 b, float2 c, float3 factor)
{
	return a * factor.x + b * factor.y + c * factor.z;
}
float3 lilLerpFloat3(float3 a, float3 b, float3 c, float3 factor)
{
	return a * factor.x + b * factor.y + c * factor.z;
}
float4 lilLerpFloat4(float4 a, float4 b, float4 c, float3 factor)
{
	return a * factor.x + b * factor.y + c * factor.z;
}

float lilLerpMask(float a, float b, float c, float3 factor)
{
	return a * factor.x + b * factor.y + c * factor.z;
}

PoiGeoToFragLilFur SetupFurOutputStructs(inout PoiGeoToFragLilFur output, PoiVertToGeoLilFur input[3], float3 furVectors[3], float3 factor)
{
	output.uv[0] = lilLerpFloat4(input[0].uv[0], input[1].uv[0], input[2].uv[0], factor);
	output.uv[1] = lilLerpFloat4(input[0].uv[1], input[1].uv[1], input[2].uv[1], factor);
	output.normal = lilLerpFloat3(input[0].normal, input[1].normal, input[2].normal, factor);
	output.vertexId = input[0].vertexId;
	
	output.fogData = lilLerpFloat(input[0].fogData, input[1].fogData, input[2].fogData, factor);
	#ifdef POIBS_BLOOMFOG
		output.bsFogScreenUV = input[0].bsFogScreenUV; // Screen UV is same for all vertices in a triangle
	#endif

	float3 posWS = lilLerpFloat3(input[0].worldPos, input[1].worldPos, input[2].worldPos, factor);
	
	output.worldPos = posWS;
	output.pos = PoiWorldToClipPos(posWS);
	output.furLayer = 0;
	
	// Apply reduce clip distance to base layer
	applyReducedRenderClipDistanceGeoFur(output.pos);
	
	#ifdef LIL_FUR_PRE
		#if defined(UNITY_REVERSED_Z)
			output.pos.z -= 0.0000001;
		#else
			output.pos.z += 0.0000001;
		#endif
	#endif
	
	PoiGeoToFragLilFur baseStruct = output;
	
	float3 furVec = lilLerpFloat3(furVectors[0], furVectors[1], furVectors[2], factor);
	posWS += furVec;
	output.worldPos = posWS;
	output.pos = PoiWorldToClipPos(posWS);
	output.furLayer = 1;
	
	// Apply reduce clip distance to fur tip layer
	applyReducedRenderClipDistanceGeoFur(output.pos);
	
	#ifdef LIL_FUR_PRE
		#if defined(UNITY_REVERSED_Z)
			output.pos.z -= 0.000001;
		#else
			output.pos.z += 0.000001;
		#endif
	#endif

	return baseStruct;
}

[poi_maxvertexcount(40)]
void geom(triangle PoiVertToGeoLilFur input[3], inout TriangleStream<PoiGeoToFragLilFur> outStream)
{
	PoiGeoToFragLilFur output;
	PoiInitStruct(PoiGeoToFragLilFur, output);

	UNITY_SETUP_INSTANCE_ID(input[0]);
	UNITY_SETUP_INSTANCE_ID(input[1]);
	UNITY_SETUP_INSTANCE_ID(input[2]);

	UNITY_TRANSFER_INSTANCE_ID(input[0], output);
	POI_INITIALIZE_VERTEX_OUTPUT_STEREO(output);

	float3 furVectors[3];
	furVectors[0] = input[0].furVector;
	furVectors[1] = input[1].furVector;
	furVectors[2] = input[2].furVector;

	#K#GEOMETRY_INPUT_MODS

	uint3 n0 = (input[0].vertexId * 3 + input[1].vertexId * 1 + input[2].vertexId * 1) * uint3(1597334677U, 3812015801U, 2912667907U);
	uint3 n1 = (input[0].vertexId * 1 + input[1].vertexId * 3 + input[2].vertexId * 1) * uint3(1597334677U, 3812015801U, 2912667907U);
	uint3 n2 = (input[0].vertexId * 1 + input[1].vertexId * 1 + input[2].vertexId * 3) * uint3(1597334677U, 3812015801U, 2912667907U);
	float3 noise0 = normalize(float3(n0) * (2.0 / float(0xffffffffU)) - 1.0);
	float3 noise1 = normalize(float3(n1) * (2.0 / float(0xffffffffU)) - 1.0);
	float3 noise2 = normalize(float3(n2) * (2.0 / float(0xffffffffU)) - 1.0);
	furVectors[0] += noise0 * _FurVector.w * _FurRandomize;
	furVectors[1] += noise1 * _FurVector.w * _FurRandomize;
	furVectors[2] += noise2 * _FurVector.w * _FurRandomize;

	#if defined(PROP_FURLENGTHMASK) || !defined(OPTIMIZER_ENABLED)
		float2 lmUV0 = input[0].uv[0].xy * _MainTex_ST.xy + _MainTex_ST.zw;
		float2 lmUV1 = input[1].uv[0].xy * _MainTex_ST.xy + _MainTex_ST.zw;
		float2 lmUV2 = input[2].uv[0].xy * _MainTex_ST.xy + _MainTex_ST.zw;
		float lenMask0 = _FurLengthMask.SampleLevel(sampler_linear_repeat, lmUV0, 0).r;
		float lenMask1 = _FurLengthMask.SampleLevel(sampler_linear_repeat, lmUV1, 0).r;
		float lenMask2 = _FurLengthMask.SampleLevel(sampler_linear_repeat, lmUV2, 0).r;
		furVectors[0] *= lenMask0;
		furVectors[1] *= lenMask1;
		furVectors[2] *= lenMask2;
	#endif

	if (_FurLayerNum == 1)
	{
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 0.0, 0.0) / 1.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(0.0, 1.0, 0.0) / 1.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(0.0, 0.0, 1.0) / 1.0));
		outStream.Append(output);
	}
	else if (_FurLayerNum >= 2)
	{
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 0.0, 0.0) / 1.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(0.0, 1.0, 1.0) / 2.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(0.0, 1.0, 0.0) / 1.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 0.0, 1.0) / 2.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(0.0, 0.0, 1.0) / 1.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 1.0, 0.0) / 2.0));
		outStream.Append(output);
	}
	if (_FurLayerNum >= 3)
	{
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 4.0, 1.0) / 6.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(0.0, 1.0, 1.0) / 2.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 1.0, 4.0) / 6.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 0.0, 1.0) / 2.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(4.0, 1.0, 1.0) / 6.0));
		outStream.Append(output);
		outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 1.0, 0.0) / 2.0));
		outStream.Append(output);
	}
	outStream.Append(SetupFurOutputStructs(output, input, furVectors, float3(1.0, 0.0, 0.0) / 1.0));
	outStream.Append(output);
	outStream.RestartStrip();
}

#T#PoiLilFurFragmentProgram
float4 frag(PoiGeoToFragLilFur i, bool facing : SV_IsFrontFace) : SV_Target
{
	UNITY_SETUP_INSTANCE_ID(i);
	UNITY_SETUP_STEREO_EYE_INDEX_POST_VERTEX(i);
	float4 mainTexture = POI2D_SAMPLER_PAN(_MainTex, _MainTex, i.uv[0].xy * _MainTex_ST.xy + _MainTex_ST.zw, 0);
	#K#FRAGMENT_LILFUR_DECLARATIONS

	#K#FRAGMENT_LILFUR_INIT_EARLY
	#K#FRAGMENT_LILFUR_INIT
	#K#FRAGMENT_LILFUR_INIT_LATE

	#K#FRAGMENT_LILFUR_COLOR_EARLY
	#K#FRAGMENT_LILFUR_COLOR
	#K#FRAGMENT_LILFUR_COLOR_LATE

	//UNITY_BRANCH
	//if (_AlphaPremultiply)
	//{
	//	poiFragData.baseColor *= saturate(poiFragData.alpha);
	//}
	poiFragData.finalColor = poiFragData.baseColor;

	#K#FRAGMENT_LILFUR_LIGHTING_EARLY
	#K#FRAGMENT_LILFUR_LIGHTING
	#K#FRAGMENT_LILFUR_LIGHTING_LATE

	#K#FRAGMENT_LILFUR_LIGHTING_ADD

	#K#FRAGMENT_LILFUR_EMISSION_EARLY
	#K#FRAGMENT_LILFUR_EMISSION
	#K#FRAGMENT_LILFUR_EMISSION_LATE
	
	// Fur Rim Lighting (from liltoon)
	// invLighting = (1.0 - directColor) * sqrt(directColor) - smooth inverse curve from direct light only
	// grayscale using simple 1/3 average, then lerp based on antiLight
	float3 furRimInvLighting = saturate((1.0 - poiLight.directColor) * sqrt(poiLight.directColor));
	float furRimAntiLightValue = lerp(1, dot(furRimInvLighting, float3(1.0/3.0, 1.0/3.0, 1.0/3.0)), _FurRimAntiLight);
	poiFragData.finalColor += i.furLayer * pow((1 - abs(dot(normalize(i.normal), poiCam.viewDir))), _FurRimFresnelPower) * furRimAntiLightValue * _FurRimColor.rgb * poiLight.directColor;

	// Multiply color by alpha in ForwardAdd pass for transparent mode (same as liltoon)
	#if defined(POI_PASS_ADD) && !defined(LIL_FUR_PRE)
		if (_FurRenderingMode == 1)
		{
			poiFragData.finalColor.rgb *= saturate(poiFragData.alpha * _AlphaBoostFA);
		}
	#endif

	#K#FRAGMENT_LILFUR_RETURN

	//clip(poiFragData.alpha - _Cutoff);
	//float debugValue = ceil(pow(poiFragData.alpha,5) * 10) / 10;
	//return float4(debugValue,debugValue,debugValue,1);
	#if defined(LIL_FUR_PRE)
		// Cutout
		poiFragData.alpha = saturate(poiFragData.alpha * 5.0 - 2.0);
		if (poiFragData.alpha == 0) discard;
	#else
		if (_FurRenderingMode == 0)
		{
			// Cutout
			poiFragData.alpha = saturate(poiFragData.alpha * 5.0 - 2.0);
			if (poiFragData.alpha == 0) discard;
		}
		else
		{
			// Transparent
			clip(poiFragData.alpha - _Cutoff);
		}
	#endif
	//clip(poiFragData.alpha - .5f);
	#K#FRAGMENT_LILFUR_ALPHA_LATE

	poiFragData.finalColor += poiFragData.emission * poiMods.globalEmission;

	// Apply Poiyomi fog system (handles all fog types without keywords)
	applyUnityFog(poiFragData.finalColor, i.fogData, _IgnoreFog);

	#K#FRAGMENT_BASE_RETURN
	return float4(poiFragData.finalColor, poiFragData.alpha) + POI_SAFE_RGB0;
}

#T#PoiLilFurFragmentFunctions
float3 applyFurAO(float3 color, float furLayer, float furNoiseMask, float furLayerGradient)
{
	#if defined(LIL_FUR_PRE)
		float furAO = _FurAO * saturate(1.0 - furLayerGradient);
		return color * (furLayer * furAO * 2.0 + 1.0 - furAO);
	#else
		if (_FurRenderingMode == 0)
		{
			float furAO = _FurAO * saturate(1.0 - furLayerGradient);
			return color * (furLayer * furAO * 2.0 + 1.0 - furAO);
		}
		else
		{
			return color * (saturate(1.0 - furNoiseMask + furNoiseMask * furLayer) * _FurAO * 1.25 + 1.0 - _FurAO);
		}
	#endif
}

void lilFur(inout PoiFragData poiFragData, in PoiMods poiMods, PoiGeoToFragLilFur i, float4 mainTex)
{
	poiFragData.baseColor = mainTex.rgb * poiThemeColor(poiMods, _Color.rgb, _ColorThemeIndex);
	
	float furLayer = i.furLayer;
	float furLayerShift = furLayer - furLayer * (_FurRootOffset) + (_FurRootOffset);
	float furLayerAbs = abs(furLayerShift);
	float furNoiseMask = 1.0;
	
	#if defined(PROP_FURNOISEMASK) || !defined(OPTIMIZER_ENABLED)
		furNoiseMask = _FurNoiseMask.Sample(sampler_linear_repeat, i.uv[0].xy * _FurNoiseMask_ST.xy + _FurNoiseMask_ST.zw).r;
	#endif
	
	#if defined(LIL_FUR_PRE)
		float furAlpha = saturate(furNoiseMask - furLayerShift * furLayerAbs * furLayerAbs * furLayerAbs + 0.25);
	#else
		float furAlpha;
		if (_FurRenderingMode == 0)
		{
			furAlpha = saturate(furNoiseMask - furLayerShift * furLayerAbs * furLayerAbs * furLayerAbs + 0.25);
		}
		else
		{
			furAlpha = saturate(furNoiseMask - furLayerShift * furLayerAbs * furLayerAbs);
		}
	#endif
	
	#if defined(PROP_FURMASK) || !defined(OPTIMIZER_ENABLED)
		furAlpha *= _FurMask.Sample(sampler_linear_repeat, i.uv[0].xy).r;
	#endif
	
	poiFragData.alpha = mainTex.a * _Color.a * furAlpha;
	
	float furLayerGradient = fwidth(i.furLayer);
	poiFragData.baseColor = applyFurAO(poiFragData.baseColor, furLayer, furNoiseMask, furLayerGradient);
}

#T#PoiLilFurFragmentFunctionCalls
lilFur(poiFragData, poiMods, i, mainTexture);

#T#PoiLilFurBasePassAOFunction
void applyFurAOSimple(inout PoiFragData poiFragData, in PoiMesh poiMesh)
{
	float mask = 1.0;
	#if defined(PROP_FURMASK) || !defined(OPTIMIZER_ENABLED)
		mask = _FurMask.Sample(sampler_linear_repeat, poiMesh.uv[0]).r;
	#endif
	poiFragData.baseColor *= (1.0 - _FurAO * mask);
}

#T#PoiLilFurBasePassAOFunctionCall
if(_FurRenderingMode == 0)
{
	applyFurAOSimple(poiFragData, poiMesh);
}

