#T#LilFurAddPassTags
//Fur AddPass
Name "Add"
Tags { "LightMode" = "ForwardAdd" }

#T#LilFurAddPassStencil
Stencil
{
	Ref [_FurStencilRef]
	ReadMask [_FurStencilReadMask]
	WriteMask [_FurStencilWriteMask]
//ifex _FurStencilType==1
	Comp [_FurStencilComp]
	Pass [_FurStencilPass]
	Fail [_FurStencilFail]
	ZFail [_FurStencilZFail]
//endex

//ifex _FurStencilType==0
	CompBack [_FurStencilBackComp]
	PassBack [_FurStencilBackPass]
	FailBack [_FurStencilBackFail]
	ZFailBack [_FurStencilBackZFail]

	CompFront [_FurStencilFrontComp]
	PassFront [_FurStencilFrontPass]
	FailFront [_FurStencilFrontFail]
	ZFailFront [_FurStencilFrontZFail]
//endex
}

#T#LilFurAddPassBlendSettings
ZWrite Off
ZClip [_FurZClip]
Cull [_FurCull]
//ifex _FurAlphaToMask==0
AlphaToMask [_FurAlphaToMask]
//endex
ZTest LEqual
ColorMask [_FurColorMask]
Offset [_FurOffsetFactor], [_FurOffsetUnits]

BlendOp [_FurBlendOpFA], [_FurBlendOpAlphaFA]
Blend [_FurSrcBlendFA] [_FurDstBlendFA], Zero One

#T#LilFurPreAddPassBlendSettings
ZWrite Off
ZClip [_FurZClip]
Cull [_FurCull]
AlphaToMask On
ZTest LEqual
ColorMask [_FurColorMask]
Offset [_FurOffsetFactor], [_FurOffsetUnits]

BlendOp [_FurBlendOpFA], [_FurBlendOpAlphaFA]
Blend [_FurSrcBlendFA] [_FurDstBlendFA], Zero One

