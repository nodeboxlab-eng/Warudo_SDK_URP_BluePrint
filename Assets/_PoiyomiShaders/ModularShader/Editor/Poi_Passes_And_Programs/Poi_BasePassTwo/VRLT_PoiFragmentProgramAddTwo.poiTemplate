// Poi fragement program from PoiFragmentProgramAdd.poiTemplate
float4 frag(VertexOut i, bool facing : SV_IsFrontFace) : SV_Target
{
	UNITY_SETUP_INSTANCE_ID(i);
	UNITY_SETUP_STEREO_EYE_INDEX_POST_VERTEX(i);

	#K#FRAGMENT_ADD_DECLARATIONS

	#K#FRAGMENT_ADD_INIT_EARLY
	#K#FRAGMENT_ADD_INIT
	#K#FRAGMENT_ADD_INIT_LATE

	#K#FRAGMENT_ADD_COLOR_EARLY
	#K#FRAGMENT_ADD_COLOR
	#K#FRAGMENT_ADD_COLOR_LATE

	
	if (_AlphaPremultiply2)
	{
		poiFragData.baseColor *= saturate(poiFragData.alpha);
	}
	poiFragData.finalColor = poiFragData.baseColor;

	#K#FRAGMENT_ADD_LIGHTING_EARLY
	#K#FRAGMENT_ADD_LIGHTING
	#K#FRAGMENT_ADD_LIGHTING_LATE

	#K#FRAGMENT_ADD_LIGHTING_ADD

	#K#FRAGMENT_ADD_EMISSION_EARLY
	#K#FRAGMENT_ADD_EMISSION
	#K#FRAGMENT_ADD_EMISSION_LATE

	#K#FRAGMENT_ADD_RETURN
	
	if (_ModeTwoPass == POI_MODE_OPAQUE)
	{
		poiFragData.alpha = 1;
	}
	
	poiFragData.alpha = pow(saturate(poiFragData.alpha), _TwoPassAlphaPower);
	float alphaToClip = abs(_TwoPassAlphaCutoffInvert - saturate(poiFragData.alpha));
	clip(alphaToClip - _TwoPassAlphaCutoff);

	if (_ModeTwoPass == POI_MODE_CUTOUT && !_AlphaToCoverage)
	{
		poiFragData.alpha = 1;
	}

	if (_AddBlendOp2 == 4)
	{
		poiFragData.alpha = saturate(poiFragData.alpha * _AlphaBoostFA);
	}

	if (_ModeTwoPass != POI_MODE_TRANSPARENT)
	{
		poiFragData.finalColor *= poiFragData.alpha;
	}

	#K#FRAGMENT_ADD_ALPHA_LATE
	
	applyUnityFog(poiFragData.finalColor, i.fogData, _IgnoreFog);
	return float4(poiFragData.finalColor, poiFragData.alpha) + POI_SAFE_RGB0;
}