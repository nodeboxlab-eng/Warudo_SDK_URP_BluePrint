#if POI_PIPE == POI_BIRP
	float4
#else
	void
#endif
frag( VertexOut i, bool facing : SV_IsFrontFace
	#if POI_PIPE == POI_URP
    	,out half4 outNormalWS : SV_Target0
	#endif
)
{
	UNITY_SETUP_INSTANCE_ID(i);
	UNITY_SETUP_STEREO_EYE_INDEX_POST_VERTEX(i);
	
    #K#FRAGMENT_DEPTH_DECLARATIONS

	#K#FRAGMENT_DEPTH_INIT_EARLY
	#K#FRAGMENT_DEPTH_INIT
	#K#FRAGMENT_DEPTH_INIT_LATE

	#K#FRAGMENT_DEPTH_COLOR_EARLY
	#K#FRAGMENT_DEPTH_COLOR
	#K#FRAGMENT_DEPTH_COLOR_LATE

    #K#FRAGMENT_DEPTH_RETURN
	
	if (_Mode == POI_MODE_OPAQUE)
	{
		poiFragData.alpha = 1;
	}

	clip(poiFragData.alpha - _Cutoff);

	#if POI_PIPE == POI_URP
		float3 normalWS = NormalizeNormalPerPixel(poiMesh.normals[0]);
		outNormalWS = half4(normalWS, 0.0) + POI_SAFE_RGB0;
	#else
		return float4(0, 1, 0, 1);
	#endif
}