float4 quaternion_mul(float4 v1, float4 v2)
{
	float4 result1 = (v1.x * v2 + v1 * v2.x);
	
	float4 result2 = float4(
		- dot(v1.yzw, v2.yzw),
		cross(v1.yzw, v2.yzw)
	);
	
	return float4(result1 + result2);
}

