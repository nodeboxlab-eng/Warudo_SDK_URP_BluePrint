	float w2 = saturate(1 - abs(i - 2));
	float w3 = saturate(1 - abs(i - 3));
	return o.uv[0].xy * w0 + o.uv[0].zw * w1 + o.uv[1].xy * w2 + o.uv[1].zw * w3;
}
#endif

